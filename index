  hideAuthMsg('signup-err'); hideAuthMsg('signup-ok');
  if(!fname||!email||!pass){ showAuthErr('signup-err','Please fill in all required fields.'); return; }
  if(!email.includes('@')){ showAuthErr('signup-err','Please enter a valid email address.'); return; }
  if(pass.length<8){ showAuthErr('signup-err','Password must be at least 8 characters.'); return; }
  if(pass!==pass2){ showAuthErr('signup-err','Passwords do not match.'); return; }
  const db=getUserDb();
  if(db[email]){ showAuthErr('signup-err','An account with this email already exists. Please sign in.'); return; }
  db[email]={fname,lname,phone,dept,pass:simpleHash(pass),createdAt:new Date().toLocaleDateString('en-IN')};
  saveUserDb(db);
  currentUser={...db[email],email};
  saveSession(currentUser);
  openDashboard();
}

