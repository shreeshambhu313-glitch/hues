/* ══ SEARCH SYSTEM v5 ══ */
function fuzzyScore(str,query){
  str=str.toLowerCase();query=query.toLowerCase();
  if(str.includes(query)) return 100;
  let score=0,si=0;
  for(let qi=0;qi<query.length&&si<str.length;qi++){
    while(si<str.length&&str[si]!==query[qi])si++;
    if(si<str.length){score+=10-(si*0.5);si++;}
  }
  return score;
}

let gsWebTimeout=null;

function gsSearch(q){
  const res=document.getElementById('gs-results');
  const clr=document.getElementById('gs-clear-btn');
  q=q.trim();
  if(clr) clr.style.display=q?'block':'none';
