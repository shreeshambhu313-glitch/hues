let selectedRoute=null, selectedSupply=null;

function selectRoute(r){
  selectedRoute=r;
  document.querySelectorAll('.route-card').forEach(c=>c.classList.remove('selected'));
  document.getElementById('route-'+r).classList.add('selected');
  const ss=document.getElementById('supply-section');
  ss.style.display='block';
  setTimeout(()=>{
    const navH=document.getElementById('nav')?.offsetHeight||90;
    const top=ss.getBoundingClientRect().top+window.scrollY-navH-32;
    window.scrollTo({top,behavior:'smooth'});
  },100);
  selectedSupply=null;
  document.querySelectorAll('.supply-card').forEach(c=>c.classList.remove('selected'));
  const autoEl=document.getElementById('supply-auto');
  const autoCheck=document.getElementById('supply-auto-check');
  if(autoEl){autoEl.style.borderColor='var(--g3)';autoEl.style.background='#fff';}
  if(autoCheck){autoCheck.style.background='';autoCheck.style.borderColor='var(--g3)';autoCheck.innerHTML='';}
  document.getElementById('finder-cta').style.display='none';
}

function selectSupply(s, auto=false){
  selectedSupply=auto?'auto':s;
  document.querySelectorAll('.supply-card').forEach(c=>c.classList.remove('selected'));
  // Reset auto option
  const autoEl=document.getElementById('supply-auto');
  const autoCheck=document.getElementById('supply-auto-check');
  if(autoEl){autoEl.style.borderColor='var(--g3)';autoEl.style.background='#fff';}
  if(autoCheck){autoCheck.style.background='';autoCheck.style.borderColor='var(--g3)';autoCheck.innerHTML='';}
  if(auto){
    // Highlight auto pill, don't highlight a supply card
    if(autoEl){autoEl.style.borderColor='var(--s)';autoEl.style.background='var(--sp)';}
    if(autoCheck){autoCheck.style.background='var(--s)';autoCheck.style.borderColor='var(--s)';autoCheck.innerHTML='✓';}
  } else {
    document.getElementById('supply-'+s).classList.add('selected');
  }
  document.getElementById('finder-cta').style.display='block';
}

