function clearCalcResult(){
  document.getElementById('calc-result').innerHTML='<div style="font-size:13px;color:var(--g4)">Paste an Amazon link above to see the GeM price.</div>';
  updateGeMPanel();
}

function toggleGeMLinkPanel(){
  const panel=document.getElementById('gem-link-panel');
  if(!panel) return;
  const open=panel.style.display==='block';
  panel.style.display=open?'none':'block';
  if(!open) updateGeMPanel();
}

function updateGeMPanel(){
  const url=document.getElementById('calc-amz-url').value.trim();
  const priceNote=document.getElementById('gem-link-price-note');
  const waBtn=document.getElementById('gem-link-wa');
  const callBtn=document.getElementById('gem-link-call');
  const gemPriceEl=document.querySelector('#calc-result .calc-gem-price');
  const gemPrice=gemPriceEl?gemPriceEl.textContent.trim():'';
