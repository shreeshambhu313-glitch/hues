  if(recentEl){
    if(!allReqs.length){
      recentEl.innerHTML='<div class="dash-empty"><div class="dash-empty-icon">📋</div><div style="font-size:15px;font-weight:700;color:var(--n);margin-bottom:6px">No requests yet</div><div style="font-size:13.5px;margin-bottom:16px">Submit your first product request to get started.</div><button class="btn btn-primary" onclick="dashNavNew()">➕ New Request</button></div>';
    } else {
      var recent3 = allReqs.slice().reverse().slice(0,3);
      recentEl.innerHTML = '<div class="req-list">' + recent3.map(function(r){
        var b=r.status==='Completed'?'done':r.status==='Active'?'active':'pending';
        var clean=(r.product||'—').replace(/\[OFFLINE QUOTATION\]/gi,'').replace(/\[Offline Quotation\]/gi,'').replace(/\[Enquiry\]/gi,'').replace(/\[Bid\]/gi,'').trim();
        return '<div class="req-item" onclick="dashNav(\'requests\')" style="cursor:pointer"><div class="req-item-top"><div class="req-item-h">'+clean+'</div><span class="req-badge '+b+'">'+r.status+'</span></div><div class="req-item-meta">Qty: '+(r.qty||'—')+' · '+r.date+'</div></div>';
      }).join('') + '</div>' +
      (allReqs.length>3 ? '<div style="text-align:center;margin-top:12px"><button class="btn btn-outline btn-sm" onclick="dashNav(\x27requests\x27)">View All '+allReqs.length+' Requests →</button></div>' : '');
    }
  }

  // Requests panel — filtered + sorted list
  var listEl = document.getElementById('dp-req-list');
  if(!listEl) return;

  // Filter by status
  var filtered = allReqs.filter(function(r){
    if(_reqFilter === 'all') return true;
    return r.status === _reqFilter;
  });

  // Filter by search
  var q = (document.getElementById('req-search') ? (document.getElementById('req-search').value||'').toLowerCase().trim() : '');
  if(q){
    filtered = filtered.filter(function(r){
      return (r.product||'').toLowerCase().includes(q) ||
             (r.qty||'').toLowerCase().includes(q) ||
             (r.extra||'').toLowerCase().includes(q) ||
             (r.date||'').includes(q);
    });
  }

  // Sort
  var sort = document.getElementById('req-sort') ? (document.getElementById('req-sort').value||'newest') : 'newest';
  filtered = filtered.slice();
  if(sort === 'newest')  filtered.reverse();
  else if(sort === 'oldest') { /* keep original order */ }
  else if(sort === 'status'){
    var order = {Active:0, Pending:1, Completed:2};
    filtered.sort(function(a,b){ return (order[a.status]||9) - (order[b.status]||9); });
  }

  if(!filtered.length){
    if(!allReqs.length){
      listEl.innerHTML = '<div class="req-empty"><div class="req-empty-icon">📋</div><div class="req-empty-h">No requests yet</div><div class="req-empty-p">Submit your first request to start tracking your procurement.</div><button class="btn btn-primary" onclick="dashNavNew()">➕ New Request</button></div>';
    } else {
      listEl.innerHTML = '<div class="req-empty"><div class="req-empty-icon">🔍</div><div class="req-empty-h">No matching requests</div><div class="req-empty-p">Try adjusting your filter or search term.</div></div>';
    }
    return;
  }

  // Map back to original allReqs indices for delete/detail
  listEl.innerHTML = filtered.map(function(r){
    var idx = allReqs.indexOf(r);
    return buildReqCard(r, idx);
  }).join('');
}

