function getStateFromPin(pin){
  if(!pin||pin.length<2) return '';
  const p3=pin.substring(0,3);
  const p2=pin.substring(0,2);
  return PIN3_STATE_MAP[p3]||PIN_STATE_MAP[p2]||'';
