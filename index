function getAmzContext(ctx){
  var url='', title='Amazon Product', amzPrice=0, gemPrice=0;
  if(ctx==='gem'||ctx==='calc'){
    url      = (document.getElementById('calc-amz-url')?document.getElementById('calc-amz-url').value:'').trim();
    var tEl  = document.querySelector('#calc-result .calc-prod-name');
    var gEl  = document.querySelector('#calc-result .calc-gem-price');
    var aEl  = document.querySelector('#calc-result .calc-amz-price');
    // Fallback to manual inputs if auto-fetch failed
    var mTitle = document.getElementById('manual-title');
    var mPrice = document.getElementById('manual-price');
    title    = tEl ? tEl.textContent.trim() : (mTitle&&mTitle.value.trim() ? mTitle.value.trim() : 'Amazon Product');
    amzPrice = aEl ? parseInt(aEl.textContent.replace(/[^\d]/g,''))||0 : (mPrice ? parseFloat(mPrice.value)||0 : 0);
    var pct  = (typeof DB!=='undefined'&&DB.services)?DB.services.amzPct||10:10;
    gemPrice = gEl ? parseInt(gEl.textContent.replace(/[^\d]/g,''))||0 : Math.ceil(amzPrice*(1+pct/100));
    if(!gemPrice && amzPrice) gemPrice = Math.ceil(amzPrice*(1+pct/100));
  } else if(ctx==='da'){
    url       = (document.getElementById('da-amz-url')?document.getElementById('da-amz-url').value:'').trim();
    var tEl2  = document.querySelector('#da-calc-result .calc-prod-name');
    var gEl2  = document.querySelector('#da-calc-result .calc-gem-price');
    var aEl2  = document.querySelector('#da-calc-result .calc-amz-price');
    var mTitle2 = document.getElementById('da-manual-title');
    var mPrice2 = document.getElementById('da-manual-price');
    title    = tEl2 ? tEl2.textContent.trim() : (mTitle2&&mTitle2.value.trim() ? mTitle2.value.trim() : 'Amazon Product');
    amzPrice = aEl2 ? parseInt(aEl2.textContent.replace(/[^\d]/g,''))||0 : (mPrice2 ? parseFloat(mPrice2.value)||0 : 0);
    var pct2 = (typeof DB!=='undefined'&&DB.services)?DB.services.amzPct||10:10;
    gemPrice = gEl2 ? parseInt(gEl2.textContent.replace(/[^\d]/g,''))||0 : Math.ceil(amzPrice*(1+pct2/100));
    if(!gemPrice && amzPrice) gemPrice = Math.ceil(amzPrice*(1+pct2/100));
  }
  return {url:url, title:title, amzPrice:amzPrice, gemPrice:gemPrice};
}

