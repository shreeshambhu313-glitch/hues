.tog-track::before{content:'';position:absolute;width:15px;height:15px;border-radius:50%;background:#fff;top:3px;left:3px;transition:transform .18s;box-shadow:0 1px 3px rgba(0,0,0,.2);}
.tog-sw input:checked+.tog-track{background:var(--s);}
