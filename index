  var btn = document.createElement('button');
  btn.className = 'track-id-reveal-copy';
  btn.textContent = 'Copy ID';
  btn.setAttribute('data-tid', trackId);
  btn.onclick = function(){ copyTrackId(this); };

  div.appendChild(label);
