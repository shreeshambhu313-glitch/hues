    // Disable submit button
    var form = document.getElementById(ctx+'-inner-form');
    if(form){
      var btn = form.querySelector('.btn-primary');
      if(btn){ btn.textContent='Submitted ✓'; btn.disabled=true; btn.style.background='var(--ok)'; }
    }
  }
}

function amzCartQtyAdj(ctx, url, delta){
