function amzQtyChange(ctx, delta){
  var inp = document.getElementById(ctx+'-amz-qty');
  if(!inp) return;
  var v = parseInt(inp.value)||1;
  v = Math.max(1, v+delta);
  inp.value = v;
}

function closeAmzActionForm(ctx){
