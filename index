.svc-mc-chk.offq{background:#FEF3EB;color:#92400E;}
.svc-mc-chk.cat{background:var(--sp);color:var(--s);}
.svc-mc-chk.req{background:#F0FDF4;color:var(--g);}
.svc-mc-btn{width:100%;padding:12px;border-radius:var(--r);font-size:13.5px;font-weight:600;border:none;cursor:pointer;text-align:center;font-family:'Plus Jakarta Sans',sans-serif;transition:opacity .15s;}
.svc-mc-btn:hover{opacity:.88;}
.svc-mc-btn.bid{background:var(--n);color:#fff;}
.svc-mc-btn.offq{background:#92400E;color:#fff;}
.svc-mc-btn.cat{background:var(--s);color:#fff;}
.svc-mc-btn.req{background:var(--g);color:#fff;}

/* How it works — timeline */
.svc-how-line{display:flex;gap:0;position:relative;margin-top:40px;}
.svc-how-line::before{content:'';position:absolute;top:21px;left:22px;right:22px;height:1px;background:var(--g2);}
.svc-hs{flex:1;text-align:center;padding:0 6px;}
.svc-hc{width:44px;height:44px;border-radius:50%;background:var(--n);color:#fff;font-family:'Lora',serif;font-size:17px;display:flex;align-items:center;justify-content:center;margin:0 auto 13px;position:relative;z-index:1;}
.svc-ht{font-size:13px;font-weight:700;color:var(--n);margin-bottom:4px;}
.svc-hd{font-size:12px;color:var(--g5);line-height:1.55;}

/* Compare table */
.svc-compare{width:100%;border-collapse:collapse;font-size:13px;table-layout:fixed;}
.svc-compare th{padding:12px 14px;text-align:left;font-weight:700;font-size:11px;letter-spacing:.5px;text-transform:uppercase;color:rgba(255,255,255,.65);background:var(--n);border-right:1px solid rgba(255,255,255,.08);}
.svc-compare th:first-child{background:var(--g1);color:var(--g5);}
.svc-compare td{padding:11px 14px;border-bottom:1px solid var(--g2);color:var(--g5);border-right:1px solid var(--g2);}
.svc-compare td:first-child{font-weight:600;color:var(--n);}
.svc-compare tr:last-child td{border-bottom:none;}
.svc-compare .yes{color:var(--ok);font-weight:700;}
.svc-compare .na{color:var(--g5);font-weight:500;}
.svc-cmp-label{font-size:18px;font-weight:700;color:var(--n);}

/* Trust strip */
.svc-trust{background:var(--n);padding:32px 0;display:flex;flex-wrap:wrap;gap:20px;justify-content:center;align-items:center;}
.svc-ti{display:flex;align-items:center;gap:9px;color:rgba(255,255,255,.55);font-size:13.5px;}
.svc-tic{width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.07);display:flex;align-items:center;justify-content:center;font-size:15px;}
.svc-tsep{width:1px;height:24px;background:rgba(255,255,255,.1);}

/* Guide card */
.svc-guide-card{background:linear-gradient(135deg,#EEF2FF,#E0E7FF);border-top:1px solid #C7D2FE;padding:52px 0;}
.svc-guide-inner{display:flex;align-items:center;gap:52px;flex-wrap:wrap;}
.svc-guide-left{flex:1;min-width:260px;}
.svc-guide-pill{display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid #C7D2FE;color:#3730A3;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;margin-bottom:16px;}
.svc-guide-h{font-family:'Lora',serif;font-size:28px;color:#1E1B4B;margin-bottom:10px;line-height:1.2;}
.svc-guide-p{font-size:14px;color:#4338CA;line-height:1.75;opacity:.85;max-width:440px;}
.svc-guide-btns{display:flex;gap:10px;margin-top:22px;flex-wrap:wrap;}
.svc-guide-btn-p{background:#4F46E5;color:#fff;padding:12px 22px;border-radius:var(--r);font-size:14px;font-weight:600;border:none;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;}
.svc-guide-btn-p:hover{background:#4338CA;}
.svc-guide-btn-s{background:#fff;color:#3730A3;padding:12px 22px;border-radius:var(--r);font-size:14px;font-weight:600;border:1px solid #C7D2FE;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;}
.svc-guide-right{display:flex;flex-direction:column;gap:10px;min-width:220px;}
.svc-guide-pt{display:flex;align-items:center;gap:10px;background:#fff;border:1px solid #C7D2FE;border-radius:var(--r);padding:10px 14px;font-size:13px;color:#3730A3;cursor:pointer;transition:all .15s;}
.svc-guide-pt:hover{background:#EEF2FF;border-color:#818CF8;}

/* Responsive */
@media(max-width:768px){
  .svc-routes-grid{grid-template-columns:1fr;}
  .svc-more-grid{grid-template-columns:1fr 1fr;}
  .svc-how-line{flex-direction:column;gap:16px;}
  .svc-how-line::before{display:none;}
  .svc-hero-stats{flex-wrap:wrap;}
  .svc-hstat{flex:0 0 50%;}
  .svc-guide-inner{flex-direction:column;}
}
@media(max-width:480px){
  .svc-more-grid{grid-template-columns:1fr;}
}

