function renderAdminRequests(){
  var filter  = document.getElementById('req-admin-filter')  ? document.getElementById('req-admin-filter').value  : 'all';
  var typeF   = document.getElementById('req-admin-type')    ? document.getElementById('req-admin-type').value    : 'all';
  var search  = document.getElementById('req-admin-search')  ? document.getElementById('req-admin-search').value.toLowerCase().trim() : '';
  var tbody   = document.getElementById('req-admin-body');
  var statsEl = document.getElementById('req-admin-stats');
  if(!tbody) return;

  var leads = DB.leads.slice();

  if(statsEl){
    var total    = leads.length;
    var newCount = leads.filter(function(l){ return l.status==='new'; }).length;
    var active   = leads.filter(function(l){ return l.status==='Active'; }).length;
    var done     = leads.filter(function(l){ return l.status==='Completed'; }).length;
    statsEl.innerHTML =
      '<div style="background:#fff;border:var(--border);border-radius:var(--r);padding:12px 16px;text-align:center;"><div style="font-size:22px;font-weight:800;color:var(--n)">'+total+'</div><div style="font-size:11px;font-weight:600;color:var(--g4);text-transform:uppercase;">Total</div></div>'+
      '<div style="background:#FEF9C3;border:1px solid #FDE047;border-radius:var(--r);padding:12px 16px;text-align:center;"><div style="font-size:22px;font-weight:800;color:#854D0E">'+newCount+'</div><div style="font-size:11px;font-weight:600;color:#854D0E;text-transform:uppercase;">New</div></div>'+
      '<div style="background:#DBEAFE;border:1px solid #93C5FD;border-radius:var(--r);padding:12px 16px;text-align:center;"><div style="font-size:22px;font-weight:800;color:#1D4ED8">'+active+'</div><div style="font-size:11px;font-weight:600;color:#1D4ED8;text-transform:uppercase;">Active</div></div>'+
      '<div style="background:#DCFCE7;border:1px solid #86EFAC;border-radius:var(--r);padding:12px 16px;text-align:center;"><div style="font-size:22px;font-weight:800;color:#15803D">'+done+'</div><div style="font-size:11px;font-weight:600;color:#15803D;text-transform:uppercase;">Completed</div></div>';
  }

  if(filter !== 'all') leads = leads.filter(function(l){ return l.status === filter; });
  if(typeF  !== 'all') leads = leads.filter(function(l){ return (l.product||'').includes(typeF); });
  if(search) leads = leads.filter(function(l){
    return (l.name||'').toLowerCase().includes(search) ||
           (l.phone||'').includes(search) ||
           (l.product||'').toLowerCase().includes(search) ||
           (l.trackId||'').toLowerCase().includes(search) ||
           (l.date||'').includes(search);
  });

  tbody.innerHTML = '';

  if(!leads.length){
    var emptyRow = document.createElement('tr');
    var emptyTd  = document.createElement('td');
    emptyTd.colSpan = 10;
    emptyTd.style.cssText = 'text-align:center;padding:24px;color:var(--g4);';
    emptyTd.textContent = 'No requests found';
    emptyRow.appendChild(emptyTd);
    tbody.appendChild(emptyRow);
    return;
  }

  leads.forEach(function(l){
    var tr = document.createElement('tr');
    var statusCls = l.status==='Completed'?'ok': (l.status==='new'||l.status==='Pending')?'pending':'active';

    // Tracking ID cell
    var td0 = document.createElement('td');
    if(l.trackId){
      var span0 = document.createElement('span');
      span0.style.cssText = 'font-family:monospace;font-size:11px;background:#EEF2FF;color:#4338CA;padding:2px 7px;border-radius:4px;font-weight:700;';
      span0.textContent = l.trackId;
      td0.appendChild(span0);
    } else { td0.textContent = '—'; }

    // Name
    var td1 = document.createElement('td');
    td1.style.fontWeight = '600';
    td1.textContent = l.name||'—';

    // Phone + WA
    var td2 = document.createElement('td');
    td2.textContent = l.phone||'—';
    if(l.phone){
      var waNum = l.phone.replace(/[^0-9]/g,'');
      var waText = 'Hello '+l.name+', your request ('+(l.trackId||'')+') is being processed. — Hues MyIndia';
      var wa = document.createElement('a');
      wa.href = 'https://wa.me/'+waNum+'?text='+encodeURIComponent(waText);
      wa.target = '_blank';
      wa.style.cssText = 'color:var(--wa);font-weight:700;font-size:14px;text-decoration:none;margin-left:6px;';
      wa.innerHTML = '&#128172;';
      td2.appendChild(wa);
    }

    // Product
    var td3 = document.createElement('td');
    td3.style.cssText = 'max-width:140px;font-size:12px;';
    td3.textContent = l.product||'—';

    // Qty
    var td4 = document.createElement('td');
    td4.textContent = l.qty||'—';

    // Msg
    var td5 = document.createElement('td');
    td5.style.cssText = 'max-width:140px;font-size:11.5px;color:var(--g5);';
    td5.textContent = l.msg||'—';

    // Date
    var td6 = document.createElement('td');
    td6.style.whiteSpace = 'nowrap';
    td6.textContent = l.date||'—';

    // Type
    var td7 = document.createElement('td');
    var typeSpan = document.createElement('span');
    typeSpan.style.cssText = 'font-size:11px;font-weight:700;padding:2px 8px;border-radius:4px;background:var(--off);color:var(--g5);';
    typeSpan.textContent = getLeadType(l.product);
    td7.appendChild(typeSpan);

    // Status badge
    var td8 = document.createElement('td');
    var sBadge = document.createElement('span');
    sBadge.className = 'lstatus '+statusCls;
    sBadge.textContent = l.status;
    td8.appendChild(sBadge);

    // Status select (Action)
    var td9 = document.createElement('td');
    var sel = document.createElement('select');
    sel.style.cssText = 'border:var(--border);border-radius:6px;padding:4px 6px;font-size:12px;font-family:\'Plus Jakarta Sans\',sans-serif;outline:none;cursor:pointer;';
    ['new','Pending','Active','Completed','Cancelled'].forEach(function(s){
      var opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      if(l.status === s) opt.selected = true;
      sel.appendChild(opt);
    });
    sel.addEventListener('change', (function(lid){ return function(){ updateLeadStatus(lid, this.value); }; })(l.id));
    td9.appendChild(sel);


    // Assigned To cell
    var td10 = document.createElement('td');
    var assignSel = document.createElement('select');
    assignSel.style.cssText = 'border:var(--border);border-radius:6px;padding:4px 6px;font-size:12px;font-family:\'Plus Jakarta Sans\',sans-serif;outline:none;cursor:pointer;min-width:120px;';
    var unassignedOpt = document.createElement('option');
    unassignedOpt.value = '';
    unassignedOpt.textContent = '— Unassigned —';
    assignSel.appendChild(unassignedOpt);
    (DB.team||[]).filter(function(m){ return m.active; }).forEach(function(m){
      var opt = document.createElement('option');
      opt.value = m.id;
      opt.textContent = m.name;
      if(l.assignedTo === m.id) opt.selected = true;
      assignSel.appendChild(opt);
    });
    assignSel.addEventListener('change', (function(lid){ return function(){ assignLead(lid, this.value); }; })(l.id));
    if(l.assignedTo && l.assignedColor){
      var dot = document.createElement('span');
      dot.style.cssText = 'display:inline-block;width:8px;height:8px;border-radius:50%;background:'+l.assignedColor+';margin-right:5px;vertical-align:middle;';
      td10.appendChild(dot);
    }
    td10.appendChild(assignSel);

    [td0,td1,td2,td3,td4,td5,td6,td7,td8,td10,td9].forEach(function(td){ tr.appendChild(td); });
    tbody.appendChild(tr);
  });
}


function getLeadType(product){
  var p = (product||'').toLowerCase();
  if(p.includes('[offline') || p.includes('[quotation')) return 'Quotation';
  if(p.includes('[enquiry'))   return 'Enquiry';
  if(p.includes('[bid'))       return 'Bid';
  if(p.includes('[dashboard')) return 'Dashboard';
  return 'Direct';
}

function updateLeadStatus(id, newStatus){
  var lead = DB.leads.find(function(l){ return l.id===id; });
  if(!lead) return;
  lead.status = newStatus;
  saveLeadsToStorage();
  updateStats();
  // Also sync tracking record status so customer sees update
  var tracked = getAllTracked();
  var tr = tracked.find(function(t){ return t.trackId===lead.trackId; });
  if(tr){ tr.status = newStatus; saveAllTracked(tracked); }
  renderAdminRequests();
  showToast('Status updated to '+newStatus,'ok');
}


