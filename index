  addLead({id:'l'+Date.now(),trackId:_tId_offq,name:nameContact||billName,phone,dept,product:productLabel,qty,msg:fullMsg,date:new Date().toLocaleDateString('en-IN'),status:'new'});
  updateStats();
  const succ=document.getElementById('offq-success');
  if(succ){ succ.style.display='block'; showTrackIdReveal(_tId_offq,'offq-success'); }
  offqFiles=[];renderFileList([],'offq-file-list');
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    if(succ){
      const navH=document.getElementById('nav')?.offsetHeight||90;
      const top=succ.getBoundingClientRect().top+window.scrollY-navH-24;
