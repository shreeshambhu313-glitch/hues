function switchSec(id,el,fromBottomNav){
  document.querySelectorAll('.a-sec').forEach(s=>s.classList.remove('on'));
  document.getElementById('sec-'+id).classList.add('on');
  document.querySelectorAll('.a-sl').forEach(l=>l.classList.remove('on'));
  if(el&&!fromBottomNav) el.classList.add('on');
  if(fromBottomNav){
    document.querySelectorAll('.a-sl').forEach(l=>{
      const oc=l.getAttribute('onclick')||'';
      if(oc.includes("'"+id+"'")) l.classList.add('on');
    });
  }
  // Sync bottom nav tabs
  document.querySelectorAll('.a-bn-item').forEach(b=>b.classList.remove('on'));
  const bnEl=document.getElementById('bn-'+id);
  if(bnEl) bnEl.classList.add('on');
  else if(fromBottomNav&&el) el.classList.add('on');
  if(id==='products') renderAProdList();
  if(id==='leads') renderLeads();
  if(id==='cats') renderAdminCats();
  if(id==='dashboard') updateStats();
  if(id==='ticker') renderTickerAdmin();
  if(id==='services') renderServicesAdmin();
  if(id==='brands') renderBrandsAdmin();
  if(id==='brand'){document.getElementById('b-name').value=DB.brand.name;document.getElementById('b-tagline').value=DB.brand.tagline;document.getElementById('b-gst').value=DB.brand.gstin;document.getElementById('b-addr').value=DB.brand.address;}
  const body=document.querySelector('.a-body');if(body) body.scrollTop=0;
}

function updateStats(){
  const active=DB.products.filter(p=>p.active!==false).length;
  const stP=document.getElementById('st-p'); if(stP) stP.textContent=active;
  const stC=document.getElementById('st-c'); if(stC) stC.textContent=DB.categories.length;
  document.getElementById('st-l').textContent=DB.leads.length;
  document.getElementById('st-n').textContent=DB.leads.filter(l=>l.status==='new'||l.status==='Pending').length;
  const stA=document.getElementById('st-active'); if(stA) stA.textContent=DB.leads.filter(l=>l.status==='Active').length;
  const stD=document.getElementById('st-done'); if(stD) stD.textContent=DB.leads.filter(l=>l.status==='Completed').length;
  // Update hero product count
  const heroCount=document.getElementById('hero-prod-count');
  if(heroCount) heroCount.textContent=active;
  const tb=document.getElementById('dash-leads');
  const r=DB.leads.slice(0,5);
  tb.innerHTML=r.length?r.map(l=>`<tr>
    <td style="font-family:monospace;font-size:11px;color:#4338CA;">${l.trackId||'—'}</td>
    <td>${l.name}</td><td>${l.phone}</td>
    <td style="max-width:120px;font-size:12px;">${(l.product||'').replace(/\[.*?\]/g,'').trim()}</td>
    <td>${l.date}</td>
    <td><span class="lstatus ${l.status}">${l.status}</span></td>
    <td><button onclick="switchSec('requests',document.querySelector('[onclick*=requests]'))" style="background:var(--s);color:#fff;border:none;border-radius:5px;padding:3px 8px;font-size:11px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;">Open</button></td>
  </tr>`).join(''):'<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--g4)">No requests yet — they will appear here when customers submit.</td></tr>';
}

/* Products admin - with search, sort, category filter */
function populateAdminCatFilter(){
  const sel=document.getElementById('a-prod-cat-filter');
  if(!sel) return;
  sel.innerHTML='<option value="">All Categories</option>';
  DB.categories.forEach(c=>{sel.innerHTML+=`<option value="${c.id}">${c.name}</option>`;});
}

function renderAProdList(){
  const q=(document.getElementById('a-prod-search')?.value||'').toLowerCase().trim();
  const catF=document.getElementById('a-prod-cat-filter')?.value||'';
  const sort=document.getElementById('a-prod-sort')?.value||'newest';
  let list=[...DB.products];
  if(q) list=list.filter(p=>p.name.toLowerCase().includes(q)||(p.brand||'').toLowerCase().includes(q)||(p.hsn||'').includes(q));
  if(catF) list=list.filter(p=>p.cat===catF);
  if(sort==='name') list.sort((a,b)=>a.name.localeCompare(b.name));
  else if(sort==='name-z') list.sort((a,b)=>b.name.localeCompare(a.name));
  else if(sort==='oldest') list.reverse();
  // newest is default (already in order)
  const tb=document.getElementById('a-prods-body');
  const availCfg=GEM_AVAIL_CONFIG;
  tb.innerHTML=list.map(p=>{
    const cat=DB.categories.find(c=>c.id===p.cat);
    const img=p.imgs&&p.imgs.length?`<img src="${p.imgs[0]}" alt="${p.name}"/>`:`<div class="at-ph">${cat?.icon||'📦'}</div>`;
    const gemA=availCfg[p.gemAvail];
    const gemBadge=gemA?`<span style="font-size:10.5px;font-weight:600;color:${p.gemAvail==='exact'?'#15803D':p.gemAvail==='similar'?'#A16207':p.gemAvail==='custom'?'#0369A1':'var(--g4)'}">${gemA.icon} ${gemA.label}</span>`:'<span style="font-size:10.5px;color:var(--g4)">—</span>';
