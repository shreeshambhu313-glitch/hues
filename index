function doLogin(){
  const email=(document.getElementById('li-email').value||'').trim().toLowerCase();
  const pass=document.getElementById('li-pass').value||'';
  hideAuthMsg('login-err'); hideAuthMsg('login-ok');
  if(!email||!pass){ showAuthErr('login-err','Please enter your email and password.'); return; }
  const db=getUserDb();
  if(!db[email]){ showAuthErr('login-err','No account found with this email. Please sign up.'); return; }
  if(db[email].pass !== simpleHash(pass)){ showAuthErr('login-err','Incorrect password. Please try again.'); return; }
  currentUser={...db[email], email};
  saveSession(currentUser);
  openDashboard();
}

