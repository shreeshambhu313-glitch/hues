var HMI_TEAM_KEY = 'hmi_team_v1';

function loadTeamFromStorage(){
  try{
    var saved = JSON.parse(localStorage.getItem(HMI_TEAM_KEY)||'null');
    if(saved && saved.length) DB.team = saved;
  }catch(e){}
}

function saveTeamToStorage(){
  try{ localStorage.setItem(HMI_TEAM_KEY, JSON.stringify(DB.team)); }catch(e){}
}

function getTeamMemberById(id){
  if(!id) return null;
  return (DB.team||[]).find(function(m){ return m.id===id; }) || null;
}

function renderTeamList(){
  var el = document.getElementById('team-list');
  if(!el) return;
  var team = DB.team||[];
  if(!team.length){
    el.innerHTML = '<div style="text-align:center;padding:32px;color:var(--g4);">No team members yet. Add one above.</div>';
    return;
  }
  el.innerHTML = '';
  team.forEach(function(m){
    var card = document.createElement('div');
    card.className = 'team-card';

    // Count assigned open requests
    var openCount = (DB.leads||[]).filter(function(l){ return l.assignedTo===m.id && l.status!=='Completed'; }).length;
    var totalCount = (DB.leads||[]).filter(function(l){ return l.assignedTo===m.id; }).length;

    var initials = m.name.split(' ').map(function(w){ return w[0]; }).slice(0,2).join('').toUpperCase();
    card.innerHTML =
      '<div class="team-avatar" style="background:'+m.color+'">'+initials+'</div>'+
      '<div class="team-info">'+
        '<div class="team-name">'+m.name+'</div>'+
        '<div class="team-role">'+m.role+'</div>'+
        '<div class="team-stats">'+openCount+' open &nbsp;·&nbsp; '+totalCount+' total assigned</div>'+
      '</div>'+
      '<div style="font-size:12px;color:var(--g4);flex-shrink:0;text-align:right;min-width:80px;">'+
        '<div style="margin-bottom:4px;">@'+m.username+'</div>'+
        '<div style="padding:2px 8px;border-radius:12px;font-weight:700;background:'+(m.active?'#DCFCE7':'var(--g1)')+';color:'+(m.active?'#15803D':'var(--g4)')+';">'+(m.active?'Active':'Inactive')+'</div>'+
      '</div>'+
      '<div class="team-actions">'+
        '<button class="team-btn" onclick="toggleTeamActive(\''+m.id+'\')">'+(m.active?'Deactivate':'Activate')+'</button>'+
        '<button class="team-btn danger" onclick="removeTeamMember(\''+m.id+'\')">Remove</button>'+
      '</div>';
    el.appendChild(card);
  });
}

function addTeamMember(){
  var name  = (document.getElementById('tm-name')?document.getElementById('tm-name').value:'').trim();
  var role  = (document.getElementById('tm-role')?document.getElementById('tm-role').value:'').trim();
  var user  = (document.getElementById('tm-user')?document.getElementById('tm-user').value:'').trim();
  var pass  = (document.getElementById('tm-pass')?document.getElementById('tm-pass').value:'').trim();
  var color = document.getElementById('tm-color')?document.getElementById('tm-color').value:'#E8651A';
  if(!name||!role||!user||!pass){ showToast('Please fill in all fields','err'); return; }
  if(pass.length<6){ showToast('Password must be at least 6 characters','err'); return; }
  if(!DB.team) DB.team=[];
  if(DB.team.find(function(m){ return m.username===user; })){ showToast('Username already exists','err'); return; }
  DB.team.push({id:'t'+Date.now(), name:name, role:role, username:user, pass:user+'_'+pass, color:color, active:true});
  saveTeamToStorage();
  ['tm-name','tm-role','tm-user','tm-pass'].forEach(function(id){ var el=document.getElementById(id); if(el)el.value=''; });
  renderTeamList();
  showToast('Team member added: '+name,'ok');
}

function removeTeamMember(id){
  if(!confirm('Remove this team member? Their assigned requests will become unassigned.')) return;
  DB.team = (DB.team||[]).filter(function(m){ return m.id!==id; });
  // Unassign from leads
  (DB.leads||[]).forEach(function(l){ if(l.assignedTo===id) { delete l.assignedTo; delete l.assignedName; } });
  saveTeamToStorage();
  saveLeadsToStorage();
  renderTeamList();
  renderAdminRequests();
  showToast('Team member removed','ok');
}

function toggleTeamActive(id){
  var m = getTeamMemberById(id);
  if(!m) return;
  m.active = !m.active;
  saveTeamToStorage();
  renderTeamList();
}

function assignLead(leadId, memberId){
  var lead = (DB.leads||[]).find(function(l){ return l.id===leadId; });
  if(!lead) return;
  if(memberId===''){
    delete lead.assignedTo;
    delete lead.assignedName;
    delete lead.assignedColor;
  } else {
    var m = getTeamMemberById(memberId);
    if(!m) return;
    lead.assignedTo    = m.id;
    lead.assignedName  = m.name;
    lead.assignedColor = m.color;
    // Auto-set status to Active when assigned
    if(lead.status==='new'||lead.status==='Pending') lead.status='Active';
    // Sync customer tracking
    var tracked = getAllTracked();
    var tr = tracked.find(function(t){ return t.trackId===lead.trackId; });
    if(tr){ tr.status='Active'; tr.assignedTo=m.name; tr.assignedColor=m.color; saveAllTracked(tracked); }
  }
  saveLeadsToStorage();
  updateStats();
  renderAdminRequests();
  showToast(memberId?'Assigned to '+lead.assignedName:'Unassigned','ok');
}

