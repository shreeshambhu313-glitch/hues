function showReqSuccess(trackId){
  // Hide the form fields, show success banner
  var form = document.getElementById('req-modal-form-area');
  var banner = document.getElementById('req-modal-success-area');
  if(form) form.style.display = 'none';
  if(banner){
    banner.style.display = 'block';
    banner.innerHTML = '';
  }
  // Build success banner
  var wrap = document.createElement('div');
  wrap.style.cssText = 'padding:24px;';

  // Close button (top right)
  var closeBtn = document.createElement('button');
  closeBtn.onclick = function(){ closeReq(); resetReqForm(); };
  closeBtn.style.cssText = 'position:absolute;top:14px;right:16px;background:var(--g1);border:none;border-radius:50%;width:32px;height:32px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--g5);';
  closeBtn.innerHTML = '&#10005;';
  if(banner) banner.appendChild(closeBtn);

  // Success content
  wrap.innerHTML =
    '<div style="text-align:center;padding:8px 0 20px;">' +
      '<div style="font-size:48px;margin-bottom:12px;">&#10003;</div>' +
      '<div style="font-family:\'Lora\',serif;font-size:20px;font-weight:600;color:var(--n);margin-bottom:6px;">Request Submitted!</div>' +
      '<div style="font-size:14px;color:var(--g5);margin-bottom:20px;">We\'ll check GeM availability and get back to you within 2 hours.</div>' +
    '</div>';

  // Tracking ID reveal
  var revealDiv = document.createElement('div');
  revealDiv.id = 'req-modal-ok-area';
  wrap.appendChild(revealDiv);
  if(banner) banner.appendChild(wrap);
  showTrackIdReveal(trackId, 'req-modal-ok-area');

  // New request button
  var newBtn = document.createElement('button');
  newBtn.className = 'btn btn-outline';
  newBtn.style.cssText = 'width:100%;justify-content:center;margin-top:16px;';
  newBtn.textContent = '+ Submit Another Request';
  newBtn.onclick = function(){ resetReqForm(); };
  wrap.appendChild(newBtn);

  // Auto-close after 30 seconds with countdown
  var countdown = 30;
  var countEl = document.createElement('div');
  countEl.style.cssText = 'text-align:center;font-size:12px;color:var(--g4);margin-top:14px;';
  countEl.textContent = 'This message will close in ' + countdown + 's';
  wrap.appendChild(countEl);

  var timer = setInterval(function(){
    countdown--;
    if(countdown <= 0){
      clearInterval(timer);
      closeReq();
      resetReqForm();
    } else {
      countEl.textContent = 'This message will close in ' + countdown + 's';
    }
  }, 1000);

  // Store timer so manual close can clear it
  if(banner) banner._autoCloseTimer = timer;
}

function resetReqForm(){
  // Clear form fields
  ['rq-name','rq-link','rq-qty','rq-budget','rq-phone','rq-pin','rq-dept','rq-msg'].forEach(function(id){
    var el = document.getElementById(id); if(el) el.value = '';
  });
  rqFiles = [];
  if(typeof renderFileList === 'function') renderFileList([], 'rq-file-list');
  // Clear error states
  if(typeof clearErrs === 'function') clearErrs('rq-name','rq-qty','rq-budget','rq-phone','rq-pin');
  // Show form, hide success
  var form = document.getElementById('req-modal-form-area');
  var banner = document.getElementById('req-modal-success-area');
  if(form) form.style.display = '';
  if(banner){
    if(banner._autoCloseTimer) clearInterval(banner._autoCloseTimer);
    banner.style.display = 'none';
    banner.innerHTML = '';
  }
}

