  if(!b.visible||!b.items.length){sec.style.display='none';return;}
  sec.style.display='block';
  // Build double set for seamless loop
  const cards=b.items.map(brand=>brandCard(brand)).join('');
  const track=document.getElementById('brands-track');
  if(track) track.innerHTML=cards+cards; // duplicate for infinite scroll
}

function brandCard(brand){
  let logoHtml='';
  if(!brand.logo){
    // No logo - show initials
    logoHtml=`<div class="brand-logo-fallback">${brand.name.substring(0,4).toUpperCase()}</div>`;
  } else if(brand.logo.startsWith('http')||brand.logo.startsWith('/')){
    // Image URL
    logoHtml=`<img class="brand-logo-img" src="${brand.logo}" alt="${brand.name}" onerror="this.parentElement.innerHTML='<div class=\"brand-logo-fallback\">${brand.name.substring(0,4).toUpperCase()}</div><div class=\"brand-name\">${brand.name}</div>'"/>`;
  } else {
    // Emoji or text
    logoHtml=`<div class="brand-logo-emoji">${brand.logo}</div>`;
  }
  const tag=brand.url?'a':'div';
  const attrs=brand.url?`href="${brand.url}" target="_blank" rel="noopener"`:'';
  return `<${tag} class="brand-card" ${attrs}>${logoHtml}<div class="brand-name">${brand.name}</div></${tag}>`;
}

function toggleBrandsVis(){
  DB.brands.visible=document.getElementById('brands-vis').checked;
  document.getElementById('brands-vis-label').textContent=DB.brands.visible?'On':'Off';
