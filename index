    if(!p) return null;
    return `${p.name}${p.brand?' ('+p.brand+')':''} × ${item.qty||1}`;
  }).filter(Boolean);

  body.innerHTML=`<div class="cart-layout">
    <div class="cart-items">${itemsHtml}</div>
    <div class="cart-summary">
      <div class="cart-summary-h">Order Summary</div>
      ${items.map(item=>{
