.a-prod-filters input:focus{border-color:var(--s);}
.a-prod-filters select{border:var(--border);border-radius:7px;padding:8px 12px;font-size:13px;outline:none;background:#fff;}
.a-prod-filters select:focus{border-color:var(--s);}
