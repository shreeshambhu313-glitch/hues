}

function cartCheckoutWA(){
  const items=cartGet();
  if(!items.length) return;
  const note=(document.getElementById('cart-note')?.value||'').trim();
  const lines=items.map((item,i)=>{
    const p=DB.products.find(x=>x.id===item.pid);
    if(!p) return null;
    return `${i+1}. ${p.name}${p.brand?' ('+p.brand+')':''} — Qty: ${item.qty||1}`;
  }).filter(Boolean).join('\n');
  let msg=`Hello Hues MyIndia,\n\nI would like a GeM quotation for the following items:\n\n${lines}`;
  if(note) msg+=`\n\nAdditional details: ${note}`;
  msg+=`\n\nPlease share GeM links and formal quotations.`;
  window.open('https://wa.me/'+DB.settings.wa+'?text='+encodeURIComponent(msg),'_blank');
}

