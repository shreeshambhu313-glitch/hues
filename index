function submitReq(){
  const name=document.getElementById('rq-name').value.trim();
  const qty=document.getElementById('rq-qty').value.trim();
  const budget=document.getElementById('rq-budget')?.value.trim()||'';
  const phone=document.getElementById('rq-phone').value.trim();
  const msg=document.getElementById('rq-msg')?.value.trim()||'';
  const rqPin=document.getElementById('rq-pin')?.value.trim()||'';
  clearErrs('rq-name','rq-qty','rq-budget','rq-phone','rq-pin');
  // Product name OR file - at least one required
  if(!name&&!rqFiles.length){markErr('rq-name','Enter a product description or attach a file');return;}
  if(!qty){markErr('rq-qty','Quantity is required');return;}
  if(!budget){markErr('rq-budget','Estimated budget is required');return;}
  if(!phone){markErr('rq-phone','Phone or email is required');return;}
  // Validate: accept phone (7+ digits) or email
  const isPhone=/^\+?[\d\s\-()]{7,}$/.test(phone);
  const isEmail=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(phone);
  if(!isPhone&&!isEmail){markErr('rq-phone','Enter a valid phone number or email address');return;}
  if(!rqPin||rqPin.length!==6){markErr('rq-pin','Valid 6-digit pincode required');return;}
  const productLabel=(name||rqFiles.map(f=>f.name).join(', ')||'Unnamed Request')+' [NEW REQUEST]';
  const fullMsg=`Product Request: ${document.getElementById('rq-link').value.trim()||'No link'}${msg?' | Notes: '+msg:''}${budget?' | Budget: '+budget:''}${rqPin?' | Pincode: '+rqPin:''}${rqFiles.length?' | Files: '+rqFiles.map(f=>f.name).join(', '):''}`;
  var _tId=genTrackId();
  saveTrackReq({trackId:_tId,product:(name||'Product Request').substring(0,50),type:'Product Request',qty:qty,budget:budget,phone:phone,date:new Date().toLocaleDateString('en-IN'),status:'Pending'});
  addLead({id:'l'+Date.now(),trackId:_tId,name:name||rqFiles[0]?.name||'File Request',phone,dept:document.getElementById('rq-dept').value.trim(),product:productLabel,qty,msg:fullMsg,date:new Date().toLocaleDateString('en-IN'),status:'new'});
  ['rq-name','rq-link','rq-qty','rq-budget','rq-phone','rq-pin','rq-dept','rq-msg'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  rqFiles=[];renderFileList([],'rq-file-list');
  updateStats();
  // Show success inline — don't close modal
  showReqSuccess(_tId);
}

