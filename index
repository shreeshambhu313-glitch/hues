    const cat=DB.categories.find(c=>c.id===r.cat);
    const img=r.imgs&&r.imgs.length
      ?`<img src="${r.imgs[0]}" alt="${r.name}"/>`
      :`<div class="related-img-ph">${cat?.icon||'📦'}</div>`;
    const price=r.showPrice&&r.price
      ?`<div class="related-price">${r.price}</div>`
      :`<div class="related-por">Price on Request</div>`;
    const gemCfg=GEM_AVAIL_CONFIG[r.gemAvail];
    const gemBadge=gemCfg?`<div class="related-gem-badge gem-avail ${gemCfg.cls}">${gemCfg.icon} ${gemCfg.label}</div>`:'';
    const waMsg=encodeURIComponent(`Hello Hues MyIndia, I want a quotation for: ${r.name}`);
    return `<div class="related-card">
      <div class="related-img" onclick="goPage('detail','${r.id}')">${img}</div>
      <div class="related-body">
        ${r.brand?`<div class="related-brand">${r.brand}</div>`:''}
        <div class="related-name" onclick="goPage('detail','${r.id}')">${r.name}</div>
        ${price}
        ${gemBadge}
        <a href="https://wa.me/${DB.settings.wa}?text=${waMsg}" target="_blank" class="related-enquire" onclick="event.stopPropagation()">💬 Quick Enquiry</a>
      </div>
    </div>`;
  }).join('');
}

/* ══ IMAGE LIGHTBOX ══ */
let lbImgs=[], lbCurrentIdx=0, lbZoomed=false, lbScale=1;

function openLightbox(idx){
  if(!lbImgs.length) return;
  lbCurrentIdx=idx||0;
  lbZoomed=false; lbScale=1;
  const lb=document.getElementById('lightbox');
  lb.classList.remove('hidden');
  requestAnimationFrame(()=>lb.classList.add('open'));
  document.body.style.overflow='hidden';
  lbRender();
  document.addEventListener('keydown',lbKeyHandler);
}

function closeLightbox(){
  const lb=document.getElementById('lightbox');
  lb.classList.remove('open');
  setTimeout(()=>lb.classList.add('hidden'),220);
  document.body.style.overflow='';
  lbZoomed=false; lbScale=1;
  document.removeEventListener('keydown',lbKeyHandler);
}

function lbRender(){
  const img=document.getElementById('lb-img');
  const wrap=document.getElementById('lb-img-wrap');
  img.src=lbImgs[lbCurrentIdx];
  img.alt=curProd?`${curProd.name} – image ${lbCurrentIdx+1}`:`Product image ${lbCurrentIdx+1}`;
  img.style.transform=`scale(1)`;
  lbZoomed=false; lbScale=1;
  wrap.classList.remove('zoomed');
  document.getElementById('lb-counter').textContent=`${lbCurrentIdx+1} / ${lbImgs.length}`;
  // Thumbnails
  const tb=document.getElementById('lb-thumbnails');
  tb.style.display=lbImgs.length>1?'flex':'none';
  tb.innerHTML=lbImgs.map((src,i)=>`<div class="lb-thumb ${i===lbCurrentIdx?'on':''}" onclick="lbGoto(${i})"><img src="${src}" alt="${curProd?curProd.name+' – image '+(i+1):'Product image '+(i+1)}"/></div>`).join('');
  // Show/hide nav arrows
  document.querySelector('.lb-prev').style.opacity=lbImgs.length>1?'1':'0';
  document.querySelector('.lb-next').style.opacity=lbImgs.length>1?'1':'0';
}

function lbNav(dir){
  lbCurrentIdx=(lbCurrentIdx+dir+lbImgs.length)%lbImgs.length;
  lbRender();
}

function lbGoto(idx){lbCurrentIdx=idx;lbRender();}

function lbToggleZoom(e){
  const img=document.getElementById('lb-img');
  const wrap=document.getElementById('lb-img-wrap');
  if(!lbZoomed){
    // Zoom to click position
    const rect=wrap.getBoundingClientRect();
    const x=((e.clientX-rect.left)/rect.width*100).toFixed(1);
    const y=((e.clientY-rect.top)/rect.height*100).toFixed(1);
    img.style.transformOrigin=`${x}% ${y}%`;
    img.style.transform='scale(2.5)';
    lbZoomed=true; lbScale=2.5;
    wrap.classList.add('zoomed');
  } else {
    img.style.transform='scale(1)';
    img.style.transformOrigin='center center';
    lbZoomed=false; lbScale=1;
    wrap.classList.remove('zoomed');
  }
}

function lbBgClick(e){
  if(e.target.id==='lightbox'||e.target.classList.contains('lb-inner')) closeLightbox();
}

function lbKeyHandler(e){
  if(e.key==='Escape') closeLightbox();
  if(e.key==='ArrowLeft') lbNav(-1);
  if(e.key==='ArrowRight') lbNav(1);
}

// Mouse wheel zoom in lightbox
// Wheel zoom - only active when lightbox is open
document.getElementById('lb-img-wrap')?.addEventListener('wheel',function(e){
  e.preventDefault();
  const img=document.getElementById('lb-img');
  const wrap=document.getElementById('lb-img-wrap');
  lbScale=Math.max(1,Math.min(4, lbScale-(e.deltaY*0.002)));
  img.style.transform=`scale(${lbScale})`;
  if(lbScale>1){wrap.classList.add('zoomed');lbZoomed=true;}
  else{wrap.classList.remove('zoomed');lbZoomed=false;}
},{passive:false});

