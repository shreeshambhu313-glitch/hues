function getReqTypeInfo(product){
  var p = (product||'').toLowerCase();
  if(p.includes('[enquiry]'))      return {icon:'✉️', cls:'type-enquiry', typeCls:'req-type-enquiry', label:'Enquiry'};
  if(p.includes('[offline'))       return {icon:'📄', cls:'type-quotation', typeCls:'req-type-quotation', label:'Quotation'};
  if(p.includes('[bid]')||p.includes('[gem bid]')) return {icon:'🏷️', cls:'type-bid', typeCls:'req-type-bid', label:'Bid'};
  if(p.includes('[amazon]'))       return {icon:'🛒', cls:'type-amazon', typeCls:'req-type-amazon', label:'Amazon→GeM'};
  return {icon:'📦', cls:'type-product', typeCls:'req-type-product', label:'Product'};
}

function getStatusSteps(status, typeInfo){
  var label = typeInfo ? typeInfo.label : 'Product';
  var steps;
  if(label === 'Quotation'){
    steps = [
      {label:'Submitted',   desc:'Request received by team'},
      {label:'Reviewing',   desc:'Checking availability & pricing'},
      {label:'Quotation Sent', desc:'Formal quotation issued'},
      {label:'Completed',   desc:'Supply arranged'}
    ];
  } else if(label === 'Bid'){
    steps = [
      {label:'Submitted',   desc:'Bid request received'},
      {label:'Assessing',   desc:'Checking GeM category & authorisation'},
      {label:'Bid Filed',   desc:'Bid submitted on GeM'},
      {label:'Completed',   desc:'Order confirmed'}
    ];
  } else if(label === 'Enquiry'){
    steps = [
      {label:'Submitted',   desc:'Enquiry received'},
      {label:'Reviewing',   desc:'Team reviewing your query'},
      {label:'Responded',   desc:'Response sent to you'},
      {label:'Resolved',    desc:'Query closed'}
    ];
  } else {
    steps = [
      {label:'Submitted',   desc:'Request received by team'},
      {label:'Processing',  desc:'Checking GeM availability'},
      {label:'Quotation Ready', desc:'Formal quotation / GeM link sent'},
      {label:'Completed',   desc:'Supply dispatched'}
    ];
  }

  var currentIdx = 0;
  if(status === 'Active')     currentIdx = 1;
  if(status === 'Completed')  currentIdx = steps.length - 1;

  return steps.map(function(s, i){
    return {
      label: s.label,
      desc:  s.desc,
      state: i < currentIdx ? 'done' : i === currentIdx ? 'current' : 'future'
    };
  });
}

function buildReqCard(r, idx){
  var type = getReqTypeInfo(r.product);
  var badgeCls = r.status==='Completed'?'done': r.status==='Active'?'active':'pending';
  var cleanTitle = (r.product||'\u2014')
    .replace(/\[OFFLINE QUOTATION\]/gi,'')
    .replace(/\[Offline Quotation\]/gi,'')
    .replace(/\[Enquiry\]/gi,'')
    .replace(/\[Bid\]/gi,'')
    .replace(/\[Amazon\]/gi,'')
    .trim();

  var steps = getStatusSteps(r.status, type);
  var tlHtml = steps.map(function(s){
    var sc = s.state==='done'?'done-step':s.state==='current'?'current-step':'';
    var dot = s.state==='done'?'\u2713':s.state==='current'?'\u25cf':'';
    return '<div class="req-tl-step '+sc+'"><div class="req-tl-dot">'+dot+'</div><div class="req-tl-label">'+s.label+'</div></div>';
  }).join('');

  var rid = (r.id||'').replace(/'/g,'');
  var qtbudget = '';
  if(r.qty)    qtbudget += '<span><strong>Qty:</strong> '+r.qty+'</span>';
  if(r.budget) qtbudget += '<span><strong>Budget:</strong> '+r.budget+'</span>';

  var html = '<div class="req-card">';
  html += '<div class="req-card-header">';
  html += '<div class="req-card-icon '+type.cls+'">'+type.icon+'</div>';
  html += '<div class="req-card-main">';
  html += '<div class="req-card-title">'+cleanTitle+'</div>';
  html += '<div class="req-card-meta"><span class="req-card-date">\ud83d\udcc5 '+(r.date||'\u2014')+'</span><span class="req-card-type '+type.typeCls+'">'+type.label+'</span></div>';
  html += '</div>';
  html += '<div class="req-card-right"><span class="req-badge '+badgeCls+'">'+(r.status||'Pending')+'</span></div>';
  html += '</div>';
  html += '<div class="req-card-body">';
  html += '<div class="req-timeline">'+tlHtml+'</div>';
  html += '<div class="req-card-qty-budget">'+qtbudget+'</div>';
  html += '</div>';
  html += '<div class="req-card-actions">';
  html += '<button class="req-card-btn" onclick="event.stopPropagation();openReqDetail(\''+rid+'\','+idx+')">View Details \u2192</button>';
  html += '<button class="req-card-btn danger" onclick="event.stopPropagation();deleteReq(\''+rid+'\')">Delete</button>';
  html += '</div>';
  html += '</div>';
  return html;
}


function renderDashReqs(){
