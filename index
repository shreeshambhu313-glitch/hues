/* Bulk CSV */
function dlSample(){
  const csv=`name,brand,category,hsn,description,price,show_price,amazon_link,direct_link,gem_avail,gem_note,spec_key_1,spec_val_1,spec_key_2,spec_val_2\nHP Printer,HP,IT Hardware & Peripherals,8443,Office laser printer,4500,true,https://amazon.in,,exact,,Print Speed,40 ppm,Paper,A4`;
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='hues_myindia_template.csv';a.click();
}
function bulkCSV(ev){
  const f=ev.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=e=>{
    const lines=e.target.result.split('\n').filter(l=>l.trim());
    if(lines.length<2){showToast('CSV appears empty.','err');return;}
    const hdrs=lines[0].split(',').map(h=>h.trim().replace(/"/g,'').toLowerCase());
    let cnt=0;
    for(let i=1;i<lines.length;i++){
      const vals=lines[i].split(',').map(v=>v.trim().replace(/^"|"$/g,''));
      if(!vals[0])continue;
      const obj={};hdrs.forEach((h,idx)=>{obj[h]=vals[idx]||'';});
      let cat=DB.categories.find(c=>c.name.toLowerCase()===obj.category?.toLowerCase());
      if(!cat){cat={id:'c'+Date.now()+i,name:obj.category||'Uncategorized',icon:'📦'};DB.categories.push(cat);}
      const specs=[];
      for(let s=1;s<=10;s++){const k=obj[`spec_key_${s}`],v=obj[`spec_val_${s}`];if(k&&v)specs.push([k,v]);}
      DB.products.unshift({id:'p'+Date.now()+i,name:obj.name,brand:obj.brand||'',cat:cat.id,hsn:obj.hsn||'',desc:obj.description||'',imgs:[],showPrice:obj.show_price==='true',price:obj.price||'',amzLink:obj.amazon_link||'',dirLink:obj.direct_link||'',gemAvail:obj.gem_avail||'',gemNote:obj.gem_note||'',active:true,specs});
      cnt++;
    }
    document.getElementById('bulk-result').textContent=`✅ ${cnt} products imported!`;
    updateStats();ev.target.value='';showToast(`${cnt} products imported!`,'ok');
  };r.readAsText(f);
}

