/* ══ SMART RELATED PRODUCT SCORING ENGINE ══
   Scores each candidate on 5 signals:
   1. Manual related list (admin-set) — highest priority
   2. Same category (strong signal)
   3. Same brand (strong signal)
   4. HSN code prefix match (same product class)
   5. Keyword overlap from name + description (semantic)
   6. Price proximity (same budget range)
══════════════════════════════════════════ */
function scoreRelated(target, candidate){
  if(candidate.id===target.id||candidate.active===false) return -1;
  let score=0;

  // 1. Admin-set manual related list - 200 pts each
  if(target.relatedIds&&target.relatedIds.includes(candidate.id)) score+=200;

  // 2. Same category - 80 pts
  if(candidate.cat===target.cat) score+=80;

  // 3. Same brand - 60 pts
  if(target.brand&&candidate.brand&&
     target.brand.toLowerCase()===candidate.brand.toLowerCase()) score+=60;

  // 4. HSN prefix match
  if(target.hsn&&candidate.hsn){
    const th=target.hsn.toString(), ch=candidate.hsn.toString();
    if(th.length>=4&&ch.length>=4&&th.slice(0,4)===ch.slice(0,4)) score+=50; // 4-digit = same class
    else if(th.length>=2&&ch.length>=2&&th.slice(0,2)===ch.slice(0,2)) score+=20; // 2-digit = same chapter
  }

  // 5. Keyword overlap - extract meaningful words (>3 chars) from name+desc
  function keywords(p){
    const stopwords=new Set(['with','from','this','that','for','the','and','per','unit','each','type','made','used','high','low','new','set','box']);
    const text=((p.name||'')+' '+(p.desc||'')).toLowerCase();
    return new Set(text.split(/\W+/).filter(w=>w.length>3&&!stopwords.has(w)));
  }
  const tk=keywords(target), ck=keywords(candidate);
  let overlap=0;
  tk.forEach(w=>{if(ck.has(w)) overlap++;});
  score+=Math.min(overlap*12, 60); // cap at 60 pts

  // 6. Price proximity (if both have prices)
  if(target.showPrice&&target.price&&candidate.showPrice&&candidate.price){
    const tp=parseFloat(target.price.replace(/[^0-9.]/g,'')||0);
    const cp=parseFloat(candidate.price.replace(/[^0-9.]/g,'')||0);
    if(tp>0&&cp>0){
      const ratio=Math.min(tp,cp)/Math.max(tp,cp);
      if(ratio>0.7) score+=20; // within 30% price range
      else if(ratio>0.4) score+=8;
    }
  }

  return score;
}

function renderRelated(p){
  const sec=document.getElementById('related-sec');
  const grid=document.getElementById('related-grid');

  // Score all active products against the current one
  const scored=DB.products
    .filter(r=>r.id!==p.id&&r.active!==false)
    .map(r=>({r, score:scoreRelated(p,r)}))
    .filter(x=>x.score>0)
    .sort((a,b)=>b.score-a.score)
    .slice(0,4)
    .map(x=>x.r);

  if(!scored.length){sec.style.display='none';return;}
  sec.style.display='block';

  // "View all" links to same category
  const viewAll=document.getElementById('related-view-all');
