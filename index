/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   ADMIN PANEL
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
#admin{display:none;position:fixed;inset:0;z-index:1200;background:var(--g1);overflow-y:auto;}
#admin.on{display:block;}
#a-login{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--n) 0%,var(--n2) 100%);padding:20px;}
.a-login-card{background:#fff;border-radius:var(--r2);padding:40px 34px;width:100%;max-width:360px;box-shadow:var(--sh3);}
.a-login-card h2{font-family:'Lora',serif;font-size:22px;color:var(--n);margin-bottom:4px;}
.a-login-card p{font-size:13px;color:var(--g5);margin-bottom:22px;}
.a-hint{background:var(--sp);border:1px solid rgba(232,101,26,.2);border-radius:7px;padding:9px 12px;font-size:12px;color:var(--g5);margin-bottom:14px;}
.a-hint strong{color:var(--s);}
.a-err{background:#FEF2F2;border:1px solid #FCA5A5;border-radius:7px;padding:8px 12px;font-size:12.5px;color:var(--err);margin-bottom:11px;display:none;}
.a-err.on{display:block;}
.a-head{background:var(--n);height:58px;display:flex;align-items:center;padding:0 20px;justify-content:space-between;position:sticky;top:0;z-index:500;}
.a-head-title{font-family:'Lora',serif;font-size:18px;color:#fff;display:flex;align-items:center;gap:9px;}
.a-head-title span{font-family:'Plus Jakarta Sans',sans-serif;font-size:10px;background:var(--s);padding:2px 7px;border-radius:3px;color:#fff;font-weight:800;}
.a-head-right{display:flex;gap:8px;}
.a-hbtn{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);color:#fff;padding:6px 13px;border-radius:6px;font-size:12px;cursor:pointer;transition:background .15s;}
.a-hbtn:hover{background:rgba(255,255,255,.18);}
.a-shell{display:flex;min-height:calc(100vh - 58px);}
.a-sb{width:196px;background:#fff;border-right:1px solid var(--g2);padding:12px 0;flex-shrink:0;overflow-y:auto;}
/* admin sidebar hides on mobile — handled in @media 640px block */
.a-sl{display:flex;align-items:center;gap:9px;padding:10px 16px;font-size:13px;font-weight:500;color:var(--g5);cursor:pointer;transition:all .15s;border-left:3px solid transparent;}
.a-sl svg{width:15px;height:15px;fill:currentColor;flex-shrink:0;}
.a-sl:hover{background:var(--g1);color:var(--n);}
.a-sl.on{background:var(--sp);color:var(--s);border-left-color:var(--s);}
.a-body{flex:1;padding:22px;overflow-y:auto;}
.a-sec{display:none;}
.a-sec.on{display:block;}
