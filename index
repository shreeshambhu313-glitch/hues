.a-bottom-nav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:600;background:#fff;border-top:1px solid var(--g2);height:60px;box-shadow:0 -2px 12px rgba(0,0,0,.08);}
.a-bn-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;border:none;background:none;font-family:'Plus Jakarta Sans',sans-serif;color:var(--g4);transition:color .15s;padding:0;}
.a-bn-item.on{color:var(--s);}
.a-bn-item svg{width:18px;height:18px;fill:currentColor;}
.a-bn-item span{font-size:9px;font-weight:700;letter-spacing:.3px;text-transform:uppercase;}
.a-pg-title{font-family:'Lora',serif;font-size:24px;color:var(--n);margin-bottom:20px;}
.a-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.a-stat{background:#fff;border-radius:var(--r);border:var(--border);padding:16px;text-align:center;}
.a-stat-n{font-family:'Lora',serif;font-size:30px;color:var(--n);}
.a-stat-l{font-size:11.5px;color:var(--g4);margin-top:2px;}
.ac{background:#fff;border-radius:var(--r2);border:var(--border);padding:20px;margin-bottom:18px;}
.ac-title{font-size:14px;font-weight:700;color:var(--n);margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;gap:10px;}
.at{width:100%;border-collapse:collapse;font-size:12.5px;}
.at th{background:var(--g1);padding:9px 12px;text-align:left;font-size:10.5px;font-weight:700;color:var(--g5);letter-spacing:.8px;text-transform:uppercase;white-space:nowrap;}
.at td{padding:10px 12px;border-bottom:1px solid var(--g2);vertical-align:middle;}
.at tr:last-child td{border-bottom:none;}
.at tr:hover td{background:rgba(232,101,26,.02);}
.at img{width:38px;height:38px;object-fit:cover;border-radius:5px;border:1px solid var(--g2);}
.at-ph{width:38px;height:38px;border-radius:5px;background:var(--g1);display:flex;align-items:center;justify-content:center;font-size:16px;}
.abtn{padding:5px 11px;border-radius:5px;font-size:11.5px;font-weight:600;cursor:pointer;border:1px solid;transition:all .12s;}
.abtn-e{background:rgba(26,50,96,.06);color:var(--n2);border-color:rgba(26,50,96,.18);}
.abtn-d{background:rgba(220,38,38,.06);color:var(--err);border-color:rgba(220,38,38,.18);}
.abtn-e:hover{background:var(--n2);color:#fff;}
.abtn-d:hover{background:var(--err);color:#fff;}
.abtn-tog{background:rgba(19,136,8,.06);color:var(--g);border-color:rgba(19,136,8,.18);}
.abtn-tog:hover{background:var(--g);color:#fff;}
.abtn-tog.disabled{background:rgba(220,38,38,.06);color:var(--err);border-color:rgba(220,38,38,.18);}
.abtn-tog.disabled:hover{background:var(--err);color:#fff;}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.afg{margin-bottom:11px;}
