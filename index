function selectBidTypePage(t){
  bidPageType=t;
  ['product','custom','boq'].forEach(x=>{
    const el=getBidEl('btype-'+x);
    if(el) el.classList.toggle('active',x===t);
  });
  if(!t) return;
  showAllBidCards();
  const sp=getBidEl('bsec-product');
  const sc=getBidEl('bsec-custom');
  const sb=getBidEl('bsec-boq');
  if(sp) sp.style.display=t==='product'?'':'none';
  if(sc) sc.style.display=t==='custom'?'':'none';
  if(sb) sb.style.display=t==='boq'?'':'none';
  if(t==='product'){
    hideBidSubmitSection();
    selectQcat(null);
    requestAnimationFrame(()=>{
      requestAnimationFrame(()=>{
        const target=getBidEl('bsec-product');
        if(target){
          const navH=document.getElementById('nav')?.offsetHeight||90;
          const top=target.getBoundingClientRect().top+window.scrollY-navH-16;
          window.scrollTo({top,behavior:'smooth'});
        }
      });
    });
  } else {
    showBidSubmitSection(t==='custom'?'bsec-custom':'bsec-boq');
  }
}

function selectQcat(q){
  bidQcat=q;
  ['q1','q2','q3','q4','mixed'].forEach(x=>{
    const el=getBidEl('qcat-'+x);
    if(el) el.classList.toggle('selected',x===q);
  });
  const disc=getBidEl('q2-disclaimer');
  if(disc) disc.style.display=(q==='q2'||q==='mixed')?'block':'none';
  const mixedNote=getBidEl('mixed-cat-note');
  if(mixedNote) mixedNote.style.display=q==='mixed'?'block':'none';
  renderBidList('prod-bid-list');
  const prodCard=getBidEl('bid-prod-required-card');
  if(q){
    if(prodCard) prodCard.style.display='';
    const scrollTarget=q==='mixed'?'mixed-cat-note':q==='q2'?'q2-disclaimer':'bid-prod-required-card';
    showBidSubmitSection(scrollTarget);
  } else {
    if(prodCard) prodCard.style.display='none';
  }
}

// ── Product row renderers ──
function makeProductRow(listId, idx, placeholder){
  const showCat=listId==='prod-bid-list'&&bidQcat==='mixed';
  const catSel=showCat?`<select id="pi-cat-${listId}-${idx}" onchange="updateBidItem('${listId}',${idx},'cat',this.value)" style="border:var(--border);border-radius:7px;padding:9px 8px;font-size:12px;outline:none;font-family:'Plus Jakarta Sans',sans-serif;width:100%;margin-bottom:6px"><option value="">Select category…</option><option value="Q2">Q2 — Authorised</option><option value="Q3">Q3 — Open+Branded</option><option value="Q4">Q4 — Open Market</option></select>`:'';
  const colStyle=showCat?'grid-column:1/-1':'';
  return `<div class="bid-product-row" id="prow-${listId}-${idx}" style="flex-wrap:wrap">
    ${catSel?`<div style="grid-column:1/-1">${catSel}</div>`:''}
    <input placeholder="${placeholder||'Exact brand, model & specifications — e.g. HP LaserJet Pro M404dn'}" id="pi-name-${listId}-${idx}" oninput="updateBidItem('${listId}',${idx},'name',this.value)"/>
    <input placeholder="Qty" id="pi-qty-${listId}-${idx}" oninput="updateBidItem('${listId}',${idx},'qty',this.value)"/>
    <input placeholder="₹ Budget" id="pi-budget-${listId}-${idx}" oninput="updateBidItem('${listId}',${idx},'budget',this.value)"/>
    <button class="bid-product-del" onclick="removeBidItem('${listId}',${idx})" title="Remove">✕</button>
  </div>`;
}

function updateBidItem(listId, idx, field, val){
  const map={'prod-bid-list':prodBidItems,'custom-bid-list':customBidItems,'boq-bid-list':boqBidItems};
  const list=map[listId];
  if(list&&list[idx]) list[idx][field]=val;
}

function removeBidItem(listId, idx){
  const map={'prod-bid-list':prodBidItems,'custom-bid-list':customBidItems,'boq-bid-list':boqBidItems};
  const list=map[listId];
  if(list){ list.splice(idx,1); renderBidList(listId); }
}

function renderBidList(listId){
  const map={'prod-bid-list':prodBidItems,'custom-bid-list':customBidItems,'boq-bid-list':boqBidItems};
  const list=map[listId];
  const ph={'prod-bid-list':'Product name, brand, model…','custom-bid-list':'Exact product required — brand, model, specifications…','boq-bid-list':'Item description / specification'};
  const el=getBidEl(listId);
  if(!el) return;
  el.innerHTML=list.map((_,i)=>makeProductRow(listId,i,ph[listId])).join('');
  list.forEach((item,i)=>{
    ['name','qty','budget'].forEach(f=>{
      const inp=document.getElementById(`pi-${f}-${listId}-${i}`);
      if(inp) inp.value=item[f]||'';
    });
  });
}

function addProdBidRow(){ prodBidItems.push({name:'',qty:'',budget:''}); renderBidList('prod-bid-list'); }
function addCustomBidRow(){
  if(customBidItems.length>=4){showToast('Max 4 items for Custom Bid','err');return;}
  customBidItems.push({name:'',qty:'',budget:''});
  renderBidList('custom-bid-list');
  // Hide add button if max reached
  const btn=document.getElementById('custom-add-btn');
  if(btn) btn.style.display=customBidItems.length>=4?'none':'flex';
}
function addBoqBidRow(){ boqBidItems.push({name:'',qty:'',budget:''}); renderBidList('boq-bid-list'); }

function handleBoqFiles(input){
  const newFiles=Array.from(input.files);
  boqDocFiles=[...boqDocFiles,...newFiles];
  renderFileList(boqDocFiles,'boq-file-list');
  showToast(`${newFiles.length} file(s) added (${boqDocFiles.length} total)`,'ok');
  input.value=''; // reset so same file can be added again
}
function handleBidDocFiles(input){
  const newFiles=Array.from(input.files);
  bidDocFiles=[...bidDocFiles,...newFiles];
  renderFileList(bidDocFiles,'bid-doc-file-list');
  showToast(`${newFiles.length} file(s) added (${bidDocFiles.length} total)`,'ok');
  input.value='';
}
function renderFileList(files, containerId){
  const el=document.getElementById(containerId);
  if(!el) return;
  if(!files.length){el.innerHTML='';return;}
  el.innerHTML='<div style="font-size:11.5px;font-weight:700;color:var(--ok);margin-bottom:6px">✅ '+files.length+' file(s) attached:</div>'+files.map((f,i)=>`<div class="bid-file-chip">📄 ${f.name} <span style="color:var(--g4);font-size:10px">${(f.size/1024).toFixed(0)}KB</span><button onclick="removeBidFile('${containerId}',${i})">✕</button></div>`).join('');
}
function removeBidFile(containerId, idx){
  if(containerId==='boq-file-list'){boqDocFiles.splice(idx,1);renderFileList(boqDocFiles,'boq-file-list');}
  else if(containerId==='rq-file-list'){rqFiles.splice(idx,1);renderFileList(rqFiles,'rq-file-list');}
  else if(containerId==='offq-file-list'){offqFiles.splice(idx,1);renderFileList(offqFiles,'offq-file-list');}
  else{bidDocFiles.splice(idx,1);renderFileList(bidDocFiles,'bid-doc-file-list');}
}

function submitBidPage(){
  const pin=getBidEl('bid-pin')?.value.trim()||'';
  const budget=getBidEl('bid-total-budget')?.value.trim()||'';
  const gemId=getBidEl('bid-gem-id')?.value.trim()||'';
  clearErrs('bid-pin','bid-total-budget','bid-gem-id');
  const defaultPrefix=`GEM/${new Date().getFullYear()}/B/`;
  if(!gemId||gemId===defaultPrefix){markErr('bid-gem-id','Complete the bid number or write NA if not published yet');return;}
  if(!pin||pin.length!==6){markErr('bid-pin','Valid 6-digit pincode required');return;}
  if(!budget){markErr('bid-total-budget','Total estimated budget is required');return;}

  let items=[];
  if(bidPageType==='product') items=prodBidItems.filter(x=>x.name.trim());
  else if(bidPageType==='custom') items=customBidItems.filter(x=>x.name.trim());
  else if(bidPageType==='boq') items=boqBidItems.filter(x=>x.name.trim());

  if(!items.length){
    showToast('Please add at least one product/item.','err');
    return;
  }

  const typeLabel={'product':'Product Bid ('+(bidQcat||'').toUpperCase()+')','custom':'Custom Bid','boq':'BOQ Bid'}[bidPageType];
  const name=getBidEl('bid-name')?.value.trim()||'Not provided';
  const phone=getBidEl('bid-phone')?.value.trim()||'';
  const dept=getBidEl('bid-dept')?.value.trim()||'';
  const deadline=getBidEl('bid-deadline')?.value||'';
  const totalBudget=budget;
  const notes=getBidEl('bid-notes')?.value.trim()||'';
  const itemsStr=items.map((x,i)=>`${i+1}. ${x.name}${x.qty?' (Qty:'+x.qty+')':''}${x.budget?' ['+x.budget+']':''}`).join(' | ');

  var _tId_bid=genTrackId();
  saveTrackReq({trackId:_tId_bid,product:'GeM Bid Request',type:'GeM Bid',qty:'',budget:budget,phone:phone,date:new Date().toLocaleDateString('en-IN'),status:'Pending'});
  addLead({
    id:'l'+Date.now(),trackId:_tId_bid,
    name,phone,dept,
    product:`[${typeLabel}] ${items[0].name.substring(0,40)}${items.length>1?' +'+(items.length-1)+' more':''}`,
    qty:`${items.length} item(s)`,
    msg:`${typeLabel} | Items: ${itemsStr} | GeM ID: ${gemId||'NA'} | Pincode: ${pin} | Deadline: ${deadline||'Not specified'} | Budget: ${totalBudget||'Not specified'}${notes?' | Notes: '+notes:''}`,
    date:new Date().toLocaleDateString('en-IN'),
    status:'new'
  });
  updateStats();

  const succ=getBidEl('bid-success-state');
  const disc=getBidEl('bid-post-disclaimer');
  if(disc) disc.style.display='block';
  if(succ) succ.style.display='block';
  showTrackIdReveal(typeof _tId_bid!=='undefined'?_tId_bid:'','bid-success-extra');
  requestAnimationFrame(()=>{
    requestAnimationFrame(()=>{
      const target=getBidEl('bid-post-disclaimer');
      if(target){
        const navH=document.getElementById('nav')?.offsetHeight||90;
        const top=target.getBoundingClientRect().top+window.scrollY-navH-24;
        window.scrollTo({top,behavior:'smooth'});
      }
    });
  });
}

function resetBidPage(){
  bidPageType=null; bidQcat=null;
  prodBidItems=[]; customBidItems=[]; boqBidItems=[];
  bidDocFiles=[]; boqDocFiles=[];
  const gemEl=getBidEl('bid-gem-id');
  if(gemEl) gemEl.value=`GEM/${new Date().getFullYear()}/B/`;
  ['bid-pin','bid-deadline','bid-total-budget','bid-name','bid-phone','bid-dept','bid-notes'].forEach(id=>{
    const el=getBidEl(id); if(el) el.value='';
  });

  // Clear file lists
  renderFileList([],'boq-file-list');
  renderFileList([],'bid-doc-file-list');

  ['product','custom','boq'].forEach(x=>{
    const el=getBidEl('btype-'+x); if(el) el.classList.remove('active');
  });
  ['q1','q2','q3','q4','mixed'].forEach(x=>{
    const el=getBidEl('qcat-'+x); if(el) el.classList.remove('selected');
  });
  ['q2-disclaimer','mixed-cat-note','bid-post-disclaimer'].forEach(id=>{
    const el=getBidEl(id); if(el) el.style.display='none';
  });
  const succ=getBidEl('bid-success-state'); if(succ) succ.style.display='none';
  ['bsec-product','bsec-custom','bsec-boq'].forEach(id=>{
    const el=getBidEl(id); if(el) el.style.display='none';
  });
  const prodCard=getBidEl('bid-prod-required-card'); if(prodCard) prodCard.style.display='none';
  ['prod-bid-list','custom-bid-list','boq-bid-list'].forEach(id=>{
    const el=getBidEl(id); if(el) el.innerHTML='';
  });
  hideBidCardsExceptType();
  hideBidSubmitSection();
  window.scrollTo({top:0,behavior:'smooth'});
}

function initBidPage(){
  const gemEl=getBidEl('bid-gem-id');
  if(gemEl) gemEl.value=`GEM/${new Date().getFullYear()}/B/`;
  if(!prodBidItems.length) addProdBidRow();
  if(!customBidItems.length) addCustomBidRow();
  if(!boqBidItems.length) addBoqBidRow();
  hideBidCardsExceptType();
  selectBidTypePage(null);
}

/* Returns the currently active/visible bid container — either pg-bid or dp-bid */
function getBidContainer(){
  const dpBid=document.getElementById('dp-bid');
  if(dpBid && dpBid.classList.contains('on')) return dpBid;
  return document.getElementById('pg-bid')||document.body;
}

/* Get element within the active bid container, falling back to document */
function getBidEl(id){
  const container=getBidContainer();
  return container.querySelector('#'+id)||document.getElementById(id);
}

function hideBidCardsExceptType(){
  const container=getBidContainer();
  const cards=container.querySelectorAll('.bid-form-card');
  cards.forEach((el,i)=>{ el.style.display=i===0?'':'none'; });
  ['bsec-product','bsec-custom','bsec-boq'].forEach(id=>{
    const el=getBidEl(id); if(el) el.style.display='none';
  });
}

function showAllBidCards(){
  const container=getBidContainer();
  container.querySelectorAll('.bid-form-card').forEach(el=>{
    if(['bid-info-card','bid-contact-card','bid-docs-card'].includes(el.id)) return;
    el.style.display='';
  });
}

function showBidSubmitSection(scrollTargetId){
  ['bid-info-card','bid-contact-card','bid-docs-card'].forEach(id=>{
    const el=getBidEl(id); if(el) el.style.display='';
  });
  // Auto-fill contact from profile every time contact card appears
  if(typeof currentUser!=='undefined'&&currentUser){
    const ph=getBidEl('bid-phone'); if(ph&&!ph.value) ph.value=currentUser.phone||'';
    const nm=getBidEl('bid-name'); if(nm&&!nm.value) nm.value=(currentUser.fname||'')+(currentUser.lname?' '+currentUser.lname:'');
    const dp=getBidEl('bid-dept'); if(dp&&!dp.value) dp.value=currentUser.dept||'';
  }
  const meta=getBidEl('bid-submit-meta');
  const primary=getBidEl('bid-submit-primary');
  if(meta) meta.style.display='';
  if(primary) primary.style.display='';
  const targetId=scrollTargetId||'bid-info-card';
  requestAnimationFrame(()=>{
    requestAnimationFrame(()=>{
      const target=getBidEl(targetId);
      if(target){
        const navH=document.getElementById('nav')?.offsetHeight||90;
        const top=target.getBoundingClientRect().top+window.scrollY-navH-16;
        window.scrollTo({top,behavior:'smooth'});
      }
    });
  });
}

function hideBidSubmitSection(){
  ['bid-info-card','bid-contact-card','bid-docs-card'].forEach(id=>{
    const el=getBidEl(id); if(el) el.style.display='none';
  });
  const meta=getBidEl('bid-submit-meta');
  const primary=getBidEl('bid-submit-primary');
  if(meta) meta.style.display='none';
  if(primary) primary.style.display='none';
}

