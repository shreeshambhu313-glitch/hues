.t-list-item{display:flex;align-items:center;gap:8px;background:var(--g1);border-radius:7px;padding:8px 12px;font-size:13px;}
.t-list-item span{flex:1;}
.t-del{padding:3px 9px;background:rgba(220,38,38,.08);color:var(--err);border:1px solid rgba(220,38,38,.18);border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;}
