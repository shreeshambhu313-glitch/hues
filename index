// Extract ASIN from any Amazon URL or HTML text
function extractAsin(t){
  return (t.match(/[/&?]dp[=/]([A-Z0-9]{10})/i)
       || t.match(/\/gp\/product\/([A-Z0-9]{10})/i)
       || t.match(/"asin"\s*:\s*"([A-Z0-9]{10})"/i)
       || t.match(/"ASIN"\s*:\s*"([A-Z0-9]{10})"/)
       || t.match(/data-asin="([A-Z0-9]{10})"/i)
       || [null,null])[1];
}

// Parse product data from HTML
function parseAmzHtml(html){
  if(!html||html.length<200) return null;
  let title='Amazon Product';
  const tM=html.match(/<span[^>]*id="productTitle"[^>]*>\s*([^<]+?)\s*<\/span>/i)
            ||html.match(/<title>\s*([^<|:–-]{10,80})/i);
  if(tM) title=tM[1].trim().replace(/^Amazon\.in\s*[:|]/i,'').replace(/Amazon\.in.*/i,'').trim();
  let price=null;
  for(const pat of [
    /class="a-price-whole">([\d,]+)</,
    /"priceAmount":([\d.]+)/,
    /id="priceblock_ourprice"[^>]*>\s*[₹]\s*([\d,]+)/,
    /id="priceblock_dealprice"[^>]*>\s*[₹]\s*([\d,]+)/,
    /"price":"([\d,]+\.?\d*)"/,
    /₹\s*([\d,]{3,})/,
    /INR\s*([\d,]+)/
  ]){
    const m=html.match(pat);
    if(m){price=parseFloat(m[1].replace(/,/g,''));if(price>10) break;}
  }
  let image=null;
  const iM=html.match(/"hiRes":"(https:[^"]+)"/)
           ||html.match(/"large":"(https:[^"]+)"/)
           ||html.match(/id="landingImage"[^>]*src="([^"]+)"/i);
  if(iM) image=iM[1];
  return price?{title,price,image}:null;
}

async function getAmzData(inputUrl){
  let url = inputUrl.trim();

  // If URL already has /dp/ASIN - extract clean URL, skip unshortening
  const dpMatch = url.match(/\/dp\/([A-Z0-9]{10})/i);
  if(dpMatch){
    url = `https://www.amazon.in/dp/${dpMatch[1]}`;
  } else if(url.includes('amzn.in')||url.includes('amzn.to')){
    // Short link - resolve via unshorten.me
    try{
      const res=await fetch(`https://unshorten.me/json/${encodeURIComponent(url)}`,{signal:AbortSignal.timeout(8000)});
      const json=await res.json();
      const resolved=(json.resolved_url||'').trim();
      if(resolved&&resolved.includes('amazon')){
        const m=resolved.match(/\/dp\/([A-Z0-9]{10})/i);
        if(m) url=`https://www.amazon.in/dp/${m[1]}`;
      }
    } catch(e){}
  }

  // Update input box with clean URL
  const inputEl=document.getElementById('calc-amz-url');
  if(inputEl) inputEl.value=url;

  // Run all proxies in parallel - first one with valid price data wins
  const enc=encodeURIComponent(url);
  const race=[
    fetch(`https://api.codetabs.com/v1/proxy?quest=${enc}`,{signal:AbortSignal.timeout(15000)})
      .then(r=>r.text()).catch(()=>''),
    fetch(`https://api.allorigins.win/get?url=${enc}`,{signal:AbortSignal.timeout(15000)})
      .then(r=>r.json()).then(j=>j.contents||'').catch(()=>''),
    fetch(`https://thingproxy.freeboard.io/fetch/${url}`,{signal:AbortSignal.timeout(15000)})
      .then(r=>r.text()).catch(()=>''),
  ];
  const htmls=await Promise.all(race);
  for(const html of htmls){
    if(html&&html.length>500&&!html.includes('503 - Service Unavailable')){
      const result=parseAmzHtml(html);
      if(result) return result;
    }
  }

  return null;
}


// Keep expandAmzUrl as alias for backward compat (used in admin product fetch too)
async function expandAmzUrl(url){
  if(url.match(/amazon\.(in|com).*\/dp\/[A-Z0-9]{10}/i)) return url;
  if(!url.includes('amzn.to')&&!url.includes('amzn.in')) return url;
  const enc=encodeURIComponent(url);
  const services=[
    `https://unshorten.me/json/${enc}`,
    `https://is.gd/forward.php?format=json&shorturl=${enc}`,
  ];
  for(const apiUrl of services){
    try{
      const res=await fetch(apiUrl,{signal:AbortSignal.timeout(7000)});
      const json=await res.json();
      const resolved=(json.resolved_url||json.url||'').trim();
      if(resolved&&resolved.includes('amazon')){
        const m=resolved.match(/\/dp\/([A-Z0-9]{10})/i);
        if(m) return `https://www.amazon.in/dp/${m[1]}`;
      }
    } catch(e){}
  }
  return url;
}


async function runCalc(){
  const inputEl=document.getElementById('calc-amz-url');
  const url=inputEl.value.trim();
  if(!url){showToast('Please enter an Amazon URL.','err');return;}
