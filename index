function markErr(id, msg){
  const el=document.getElementById(id);
  if(!el) return;
  el.classList.add('err');
  el.focus();
  el.scrollIntoView({behavior:'smooth',block:'center'});
  let errEl=el.parentElement.querySelector('.err-msg');
  if(!errEl){errEl=document.createElement('div');errEl.className='err-msg';el.parentElement.appendChild(errEl);}
  errEl.textContent=msg;
  errEl.classList.add('show');
  const evName=el.tagName==='SELECT'?'change':'input';
  el.addEventListener(evName,()=>{
    el.classList.remove('err');
    if(errEl) errEl.classList.remove('show');
  },{once:true});
}
function clearErrs(...ids){
  ids.forEach(id=>{
    const el=document.getElementById(id);
    if(el) el.classList.remove('err');
    if(el&&el.parentElement){
      const em=el.parentElement.querySelector('.err-msg');
      if(em) em.classList.remove('show');
    }
  });
}

/* ══ SERVICE CHARGES MODAL ══ */
function openSlab(){
  const rows=document.getElementById('slab-rows');
  const total=DB.services.tiers.length||1;
  // Gradient: highest rate = red, lowest = green, interpolate for middle
  const gradColors=[
    {r:232,g:101,b:26},  // orange (highest)
    {r:245,g:158,b:11},  // amber (mid)
    {r:34,g:197,b:94}    // green (lowest)
  ];
  function getGradColor(pos){
    // pos 0=highest rate, 1=lowest rate
    const t=pos*(gradColors.length-1);
    const lo=Math.floor(t), hi=Math.min(lo+1,gradColors.length-1);
    const f=t-lo;
    const c0=gradColors[lo], c1=gradColors[hi];
    const r=Math.round(c0.r+(c1.r-c0.r)*f);
    const g=Math.round(c0.g+(c1.g-c0.g)*f);
    const b=Math.round(c0.b+(c1.b-c0.b)*f);
    return 'rgb('+r+','+g+','+b+')';
  }
  // Sort tiers by pct descending to assign colours (highest pct = red)
  const sortedPcts=DB.services.tiers.map(function(t){return t.pct;}).sort(function(a,b){return b-a;});
  rows.innerHTML=DB.services.tiers.map(function(t,i){
    const rank=sortedPcts.indexOf(t.pct);
    const pos=total>1?rank/(total-1):0;
    const color=getGradColor(pos);
    const bgAlpha=pos<0.4?'rgba(232,101,26,0.06)':pos<0.7?'rgba(245,158,11,0.06)':'rgba(34,197,94,0.06)';
    return '<div class="slab-row slab-row-hover" onclick="selectSlab('+i+')" id="slab-row-'+i+'" style="cursor:pointer;transition:all .22s;background:'+bgAlpha+';border-color:'+color+'22;">'+
      '<div style="width:22px;height:22px;border-radius:50%;border:2px solid var(--g3);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;transition:all .18s;" id="slab-radio-'+i+'"></div>'+
      '<div style="flex:1">'+
        '<div class="slab-label">'+t.label+
          (t.upfront?'<span style="background:var(--ok);color:#fff;font-size:9px;padding:2px 7px;border-radius:4px;font-weight:800;letter-spacing:.5px;margin-left:6px;vertical-align:middle">LOWEST</span>':'')+
        '</div>'+
        '<div class="slab-cond">'+t.cond+'</div>'+
      '</div>'+
      '<div class="slab-pct" style="color:'+color+';">'+t.pct+'%</div>'+
    '</div>';
  }).join('');
  document.getElementById('slab-cta').style.display='none';
  const modal=document.getElementById('slab-modal');
  modal.style.display='flex';
  document.getElementById('slab-modal-inner').style.transform='translateY(0)';
  document.body.style.overflow='hidden';
}
function selectSlab(idx){
  const tiers=DB.services.tiers;
  tiers.forEach(function(_,i){
    const row=document.getElementById('slab-row-'+i);
    const radio=document.getElementById('slab-radio-'+i);
    if(row){row.style.background='';row.style.borderColor='';row.style.transform='';row.style.boxShadow='';}
    if(radio){radio.style.background='';radio.style.borderColor='var(--g3)';radio.innerHTML='';}
  });
  const row=document.getElementById('slab-row-'+idx);
  const radio=document.getElementById('slab-radio-'+idx);
  // Get the colour used for this row from its current border-color or fallback to brand
  const rowEl=document.getElementById('slab-row-'+idx);
  const pctEl=rowEl?rowEl.querySelector('.slab-pct'):null;
  const rowColor=pctEl?pctEl.style.color:'var(--s)';
  if(row){row.style.transform='translateX(4px) scale(1.01)';row.style.boxShadow='0 2px 12px '+rowColor+'55';row.style.borderColor=rowColor;}
  if(radio){radio.style.background=rowColor;radio.style.borderColor=rowColor;radio.style.color='#fff';radio.innerHTML='&#10003;';}
  const t=tiers[idx];
  const msg=encodeURIComponent('Hello Hues MyIndia, I have some products to be purchased and I am interested in your Local Purchase Facilitation service at '+t.pct+'% service charge ('+t.label+'). Let\'s chat.');
  const ctaDiv=document.getElementById('slab-cta');
  const ctaText=document.getElementById('slab-cta-text');
  const waBtn=document.getElementById('slab-wa-btn');
  const callBtn=document.getElementById('slab-call-btn');
  if(ctaText) ctaText.innerHTML='🎉 Great choice! You\'re eligible for our <strong>'+t.pct+'% service charge</strong> on orders '+t.label+'. Reach out and let\'s get your procurement moving:';
  if(waBtn) waBtn.href='https://wa.me/'+DB.settings.wa+'?text='+msg;
  if(callBtn) callBtn.href='tel:'+DB.settings.phone;
  if(ctaDiv) ctaDiv.style.display='block';
}
function closeSlab(){
  document.getElementById('slab-modal').style.display='none';
  document.getElementById('slab-modal-inner').style.transform='translateY(20px)';
  document.body.style.overflow='';
}

