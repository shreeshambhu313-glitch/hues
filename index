/* ==============================================
   UNIVERSAL REQUEST TRACKING — HMI-YYYYMMDD-XXXX
   Works for ALL users, login not required.
   Stored in localStorage on this device.
   ============================================== */
var HMI_TRACK_KEY = 'hmi_track_v1';

function genTrackId(){
  var now = new Date();
  var d = now.getFullYear().toString()
    + String(now.getMonth()+1).padStart(2,'0')
    + String(now.getDate()).padStart(2,'0');
  var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  var rand = '';
  for(var i=0;i<4;i++) rand += chars[Math.floor(Math.random()*chars.length)];
  return 'HMI-'+d+'-'+rand;
}

function getAllTracked(){
  try{ return JSON.parse(localStorage.getItem(HMI_TRACK_KEY)||'[]'); }
  catch(e){ return []; }
}

function saveAllTracked(arr){
  try{ localStorage.setItem(HMI_TRACK_KEY, JSON.stringify(arr.slice(0,60))); }catch(e){}
}

function saveTrackReq(opts){
  var arr = getAllTracked();
  arr.unshift(opts);
  saveAllTracked(arr);
  return opts.trackId;
}

function getTrackedById(id){
  return getAllTracked().find(function(r){ return r.trackId===id; }) || null;
}

function copyTrackId(btn){
  var id = btn.getAttribute('data-tid');
  if(!id) return;

  function onSuccess(){
    btn.textContent = '✓ Copied!';
    btn.style.background = 'var(--ok)';
    setTimeout(function(){
      btn.textContent = 'Copy ID';
      btn.style.background = '';
    }, 2500);
  }

  // Always use textarea fallback — works everywhere including file:// and HTTP
  var ta = document.createElement('textarea');
  ta.value = id;
  ta.setAttribute('readonly', '');
  ta.style.cssText = 'position:fixed;top:0;left:0;width:2em;height:2em;opacity:0;z-index:9999;';
  document.body.appendChild(ta);
  ta.focus();
  ta.select();
  ta.setSelectionRange(0, 99999);
  var ok = false;
  try{ ok = document.execCommand('copy'); }catch(e){}
  document.body.removeChild(ta);

  if(ok){
    onSuccess();
  } else if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(id).then(onSuccess).catch(function(){
      // Last resort — prompt user to copy manually
      window.prompt('Press Ctrl+C / Cmd+C to copy your tracking ID:', id);
    });
  } else {
    window.prompt('Press Ctrl+C / Cmd+C to copy your tracking ID:', id);
  }
}

function showTrackIdReveal(trackId, containerId){
  var el = document.getElementById(containerId);
  if(!el) return;
  var div = document.createElement('div');
  div.className = 'track-id-reveal';

  var label = document.createElement('div');
  label.className = 'track-id-reveal-label';
  label.textContent = 'Your Tracking Number';

  var code = document.createElement('div');
  code.className = 'track-id-reveal-code';
