.ot-card{background:var(--g1);border-radius:8px;padding:13px;margin-bottom:9px;border:var(--border);}
.ot-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}

/* ━━━━━━━━━━━━━━━━━━━━━━━━
   RESPONSIVE
━━━━━━━━━━━━━━━━━━━━━━━━ */
/* ── TABLET (≤1024px) ── */
/* ── LARGE DESKTOP (≤1400px) ── */
@media(max-width:1400px){
  .wrap{padding:0 48px;}
}
/* ── MEDIUM DESKTOP (≤1200px) ── */
@media(max-width:1200px){
  .wrap{padding:0 36px;}
  .hero-h{font-size:56px;}
  .sec-h{font-size:38px;}
}
/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   DESKTOP FONT SIZE UPGRADES
   Base body text bumped from ~14px to 16px norm
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
/* Body base */
body{font-size:16px;}

/* Navigation */
.nl{font-size:15.5px!important;}
.nl-cta{font-size:15.5px!important;}

/* Section labels & headings */
.sec-tag{font-size:13px;}
.sec-h{font-size:46px;}
.sec-lead{font-size:19px;}

/* Hero */
.hero-h{font-size:72px;}
.hero-p{font-size:20px;}
.hstat-n{font-size:46px;}
.hstat-l{font-size:16px;}
.hero-eyebrow{font-size:12px;}
.hsc-title{font-size:19px;}
.hsc-desc{font-size:16px;}

/* Buttons */
.btn{font-size:16px;}
.btn-lg{font-size:18px;}
.btn-sm{font-size:14px;}

/* Product cards */
.pc-name{font-size:15px;}
.pc-desc{font-size:13px;}
.pc-price-val{font-size:17px;}
.pcb{font-size:13.5px;}

/* Product detail */
.det-name{font-size:34px!important;}
.spec-tbl td{font-size:14.5px;}
.fg label{font-size:14px;}
.fg input,.fg textarea,.fg select{font-size:15.5px;padding:13px 16px;}
.enq-submit{font-size:15px;}
.enq h4{font-size:20px;}
.bc{font-size:13.5px;}

/* Category cards */
.cat-name{font-size:16px;}
.cat-cnt{font-size:12px;}

/* Service bar */
.svc-text strong{font-size:15px;}
.svc-text span{font-size:13px;}

/* Trust bar */
.trust-item{font-size:14.5px;}

/* Footer */
.foot-col-h{font-size:13px;}

/* Ticker */
.t-item{font-size:13px;}
.t-label{font-size:11px;}

/* Topbar */
.tb-link{font-size:14px;}

/* Modals */
.modal-head h3{font-size:22px;}
.slab-label{font-size:14.5px;}
.slab-pct{font-size:20px;}
.req-note{font-size:14px;}

/* Search */
.nav-search-bar input{font-size:16px;}
.gsr-info strong{font-size:14px;}
.gsr-info span{font-size:12.5px;}

/* Breadcrumb */
.bc{font-size:13.5px;}

/* Chips & filters */
.chip{font-size:13.5px;}

/* Offer strip */
.offer-strip-text{font-size:14px;}
.offer-strip-cta{font-size:13.5px;}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   TABLET (≤1024px)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
@media(max-width:1024px){
  .wrap{padding:0 32px;}
  .hero-h{font-size:54px;}
  .sec-h{font-size:38px;}
  .hero-p{font-size:18px;}
  .hstat-n{font-size:38px;}
  .hero-grid{grid-template-columns:1fr;gap:40px;}
  .hero-bg{display:none;}
  .amz-calc-inner{grid-template-columns:1fr;}
  .calc-input-row{flex-wrap:wrap;}
  .calc-input-row #gem-link-btn,.calc-input-row #da-gem-link-btn{flex:1 1 100%;width:100%!important;text-align:center;}
  .tg-inner{grid-template-columns:1fr;gap:32px;}
  .detail-grid{grid-template-columns:1fr;gap:16px;}
  .detail-grid>.gal{order:0;}
  .detail-grid>div:not(.gal){order:1;}
  .gal-main{height:320px!important;}
  .gal{position:static!important;top:auto!important;}
  .foot-grid{grid-template-columns:1fr 1fr;}
  .svc-bar-inner{grid-template-columns:1fr 1fr;}
  .nav-wrap{height:76px;padding:0 32px;}
  .sec{padding:72px 0;}
  #hero{padding:80px 0 72px;}
  .related-grid{grid-template-columns:repeat(2,1fr);}
  .prod-grid{grid-template-columns:repeat(auto-fill,minmax(220px,1fr));}
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   MEDIUM — navbar search drops to second row (≤1280px)
   Logo + nav links on row 1, search bar full-width on row 2
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
@media(max-width:1280px){
  .nav-wrap{
    flex-wrap:wrap;
    height:auto;
    padding:10px 28px 10px;
    gap:0;
  }
  .logo{flex-shrink:0;margin-right:auto;}
  .nav-links{flex-shrink:0;order:2;}
  .nav-search-center{
    order:3;
    flex:0 0 100%;
    margin:8px 0 6px;
    justify-content:flex-start;
  }
  .nav-search-bar{
    width:100%!important;
  }
  #gs-results{min-width:unset;width:100%;}
  /* Slightly tighten nav link padding */
  .nl{padding:8px 10px;font-size:14px;}
  .nl-cta{padding:8px 14px!important;font-size:14px!important;}
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   MOBILE (≤768px)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
@media(max-width:768px){
  .wrap{padding:0 18px;}

  /* Navbar — hamburger mode */
  .nav-links{display:none;}
  .ham{display:flex;}
  .nav-wrap{flex-wrap:wrap;height:auto;padding:10px 18px 8px;}
  .logo{margin-right:auto;}
  .nav-search-center{order:3;flex:0 0 100%;margin:6px 0 8px;}
  .nav-search-bar{width:100%!important;}
  #gs-results{width:100%;left:0;right:0;min-width:unset;}

  /* Logo */
  .logo-icon{width:40px;height:40px;}
  .logo-name{font-size:20px;}

  /* Topbar */
  .tb-inner{padding:0 18px;flex-direction:column;gap:4px;align-items:flex-start;}
  .trust-bar-inner{padding:0 18px;}
  .offer-strip{padding:10px 18px;}

  /* Hero */
  .hero-h{font-size:38px;line-height:1.1;}
  .hero-p{font-size:16px;}
  .hstat-n{font-size:30px;}
  .hstat-l{font-size:14px;}
  .hero-stats{gap:20px;}
  .hero-svcs{grid-template-columns:1fr;}
  .hero-btns{flex-direction:column;gap:10px;}
  .hero-btns .btn{width:100%;justify-content:center;}
  #hero{padding:48px 0 52px;}

  /* Sections */
  .sec{padding:48px 0;}
  .sec-h{font-size:28px;}
  .sec-lead{font-size:16px;max-width:100%;}

  /* Service bar */
  .svc-bar-inner{grid-template-columns:1fr;padding:0;}
  .svc-item{border-right:none!important;border-bottom:1px solid var(--g2);padding:14px 18px;}
  .svc-item:last-child{border-bottom:none;}

  /* Products grid */
  .prod-grid{grid-template-columns:repeat(2,1fr);gap:12px;}
  .pc-img{height:150px;}
  .pc-body{padding:10px;}
  .pc-name{font-size:13px;}
  .pc-btns{grid-template-columns:1fr 1fr;}

  /* Category carousel */
  .cat-card{flex:0 0 140px;padding:14px 10px;}
  .cat-emoji{font-size:26px;margin-bottom:6px;}
  .cat-name{font-size:13px;}

  /* How grid */
  .how-grid{grid-template-columns:1fr 1fr;}

  /* Footer */
  .foot-grid{grid-template-columns:1fr;}
  .foot-brand p{font-size:14px;}

  /* Detail page */
  .det-name{font-size:24px!important;}
  .gal-main{height:240px!important;}
  .related-grid{grid-template-columns:repeat(2,1fr)!important;gap:10px!important;}
  .related-img{height:120px;}
  .bc{font-size:12px;}

  /* Buttons */
  .btn-lg{padding:14px 22px;font-size:16px;}

  /* Bid homepage section */
  .bid-home-grid{grid-template-columns:1fr!important;gap:24px;}
  .bid-how-box{width:100%;border-radius:var(--r2)!important;}
  .bid-type-selector{grid-template-columns:1fr;}
  .qcat-grid{grid-template-columns:1fr;}
  .bid-product-row{grid-template-columns:1fr 60px;}
  .bid-page-title{font-size:26px;}

  /* Floater buttons */
  .fl-req{
    top:auto!important;bottom:88px!important;
    transform:none!important;left:0!important;
    flex-direction:column!important;
    width:38px!important;padding:10px 8px!important;
    gap:0!important;border-radius:0 14px 14px 0!important;
  }
  .fl-req-icon{display:none!important;}
  .fl-req-label{
    writing-mode:vertical-rl!important;
    transform:rotate(180deg)!important;
    text-transform:uppercase!important;
    letter-spacing:1px!important;
    font-size:9.5px!important;
    font-weight:800!important;
    white-space:normal!important;
    word-break:break-word!important;
    text-align:center!important;
    line-height:1.2!important;
    max-width:none!important;
    opacity:1!important;
    overflow:visible!important;
    width:18px;
  }

  /* Admin */
  .a-sb{display:none!important;}
  .a-body{padding:14px;padding-bottom:80px;}
  .a-shell{display:block;}
  .a-bottom-nav{display:flex!important;}

  /* Stats bar */
  .a-stats{grid-template-columns:1fr 1fr;}

  /* Ticker hide on very small */
  .t-label{display:none;}

  /* CTA Band */
  .cta-left{padding:40px 24px 32px;}
  .cta-right{flex:0 0 100%;border-left:none;border-top:1px solid rgba(255,255,255,.1);padding:28px 24px 36px;}
  .cta-h{font-size:28px;}
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   SMALL MOBILE (≤400px)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
@media(max-width:400px){
  .hero-h{font-size:32px;}
  .sec-h{font-size:24px;}
  .prod-grid{grid-template-columns:1fr 1fr;gap:8px;}
  .cat-card{flex:0 0 120px;}
  .wrap{padding:0 14px;}
  .nav-wrap{padding:8px 14px 6px;}
  .det-name{font-size:22px!important;}
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   IMAGE ZOOM LIGHTBOX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
.gal-zoom-btn{position:absolute;bottom:12px;right:12px;width:36px;height:36px;background:rgba(0,0,0,.45);border:none;border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;font-size:16px;z-index:2;transition:background .15s;backdrop-filter:blur(4px);}
.gal-zoom-btn:hover{background:rgba(0,0,0,.7);}
.gal-main{position:relative;}

#lightbox{position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.95);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .22s;}
#lightbox.open{opacity:1;}
#lightbox.hidden{display:none;}
.lb-inner{position:relative;width:100%;height:100%;display:flex;align-items:center;justify-content:center;}
.lb-img-wrap{
  position:relative;overflow:hidden;
  width:min(90vw,900px);height:min(85vh,800px);
  display:flex;align-items:center;justify-content:center;
  cursor:zoom-in;
}
.lb-img-wrap.zoomed{cursor:zoom-out;}
#lb-img{
  max-width:100%;max-height:100%;object-fit:contain;
  transition:transform .2s ease;
  transform-origin:center center;
  user-select:none;pointer-events:none;
}
.lb-close{position:fixed;top:20px;right:24px;width:44px;height:44px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:50%;color:#fff;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;border:none;z-index:10;transition:background .15s;}
.lb-close:hover{background:rgba(255,255,255,.25);}
.lb-nav{position:fixed;top:50%;transform:translateY(-50%);width:48px;height:48px;background:rgba(255,255,255,.1);border:none;border-radius:50%;color:#fff;font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10;transition:all .15s;}
.lb-nav:hover{background:rgba(255,255,255,.25);transform:translateY(-50%) scale(1.08);}
.lb-prev{left:20px;}
.lb-next{right:20px;}
.lb-counter{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.6);font-size:13px;font-weight:600;background:rgba(0,0,0,.4);padding:5px 14px;border-radius:20px;z-index:10;backdrop-filter:blur(4px);}
.lb-thumbnails{position:fixed;bottom:60px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:10;}
.lb-thumb{width:52px;height:52px;border-radius:7px;overflow:hidden;border:2px solid rgba(255,255,255,.2);cursor:pointer;transition:border-color .15s;flex-shrink:0;}
.lb-thumb.on{border-color:var(--s);}
.lb-thumb img{width:100%;height:100%;object-fit:cover;}
.lb-zoom-hint{position:fixed;top:24px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.45);font-size:12px;background:rgba(0,0,0,.3);padding:4px 12px;border-radius:20px;backdrop-filter:blur(4px);}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   RELATED PRODUCTS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
.related-sec{border-top:2px solid var(--g2);margin-top:60px;padding-top:44px;}
.related-sec-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.related-view-all{font-size:13.5px;font-weight:600;color:var(--s);cursor:pointer;text-decoration:none;}
.related-view-all:hover{text-decoration:underline;}
.related-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.related-card{background:#fff;border:var(--border);border-radius:var(--r2);overflow:hidden;cursor:pointer;transition:all .22s;display:flex;flex-direction:column;}
.related-card:hover{box-shadow:var(--sh3);border-color:var(--s);transform:translateY(-3px);}
.related-img{height:150px;background:var(--g1);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;}
.related-img img{width:100%;height:100%;object-fit:cover;transition:transform .3s;}
.related-card:hover .related-img img{transform:scale(1.06);}
.related-img-ph{font-size:44px;opacity:.2;}
.related-body{padding:14px 14px 16px;flex:1;display:flex;flex-direction:column;}
.related-brand{font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--s);text-transform:uppercase;margin-bottom:4px;}
.related-name{font-size:14px;font-weight:700;color:var(--n);line-height:1.3;margin-bottom:8px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.related-price{font-size:14px;font-weight:700;color:var(--s);}
.related-por{font-size:12px;color:var(--g4);}
.related-gem-badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;margin-top:6px;}
.related-enquire{margin-top:10px;width:100%;padding:8px;background:var(--n);color:#fff;border:none;border-radius:7px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:background .15s;}
.related-enquire:hover{background:var(--s);}



/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   BRANDS MARQUEE SECTION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
.brands-sec{background:#ffffff;padding:52px 0;border-top:1px solid var(--g2);}
.brands-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:36px;}
.brands-title{font-family:'Lora',serif;font-size:22px;color:var(--n);}
.brands-subtitle{font-size:14px;color:var(--g4);}

/* Marquee track */
.brands-marquee-wrap{position:relative;overflow:hidden;}
.brands-marquee-wrap::before,.brands-marquee-wrap::after{
  content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none;
}
.brands-marquee-wrap::before{left:0;background:linear-gradient(90deg,#fff,transparent);}
.brands-marquee-wrap::after{right:0;background:linear-gradient(270deg,#fff,transparent);}
.brands-track{display:flex;gap:20px;width:max-content;animation:brands-scroll 28s linear infinite;}
.brands-track:hover{animation-play-state:paused;}
@keyframes brands-scroll{
  0%{transform:translateX(0);}
  100%{transform:translateX(-50%);}
}
/* Brand card — no box, just logo + name floating */
.brand-card,.brand-card:link,.brand-card:visited,.brand-card:active{
  display:flex!important;flex-direction:column;align-items:center;justify-content:center;
  gap:8px;width:120px;
  background:none!important;border:none!important;box-shadow:none!important;
  padding:8px 12px;flex-shrink:0;
  cursor:pointer;
  text-decoration:none!important;color:var(--n)!important;
  transition:transform .18s,opacity .18s;
  outline:none;
}
.brand-card:hover{transform:translateY(-3px)!important;opacity:.8;}
.brand-logo-img{width:80px;height:40px;object-fit:contain;display:block;background:none;filter:grayscale(20%);}
.brand-card:hover .brand-logo-img{filter:none;}
.brand-logo-emoji{font-size:42px;line-height:1;background:none;}
.brand-logo-fallback{
  font-size:18px;font-weight:800;color:var(--n);
  letter-spacing:2px;text-transform:uppercase;
  background:none!important;border:none;
}
.brand-name{font-size:11.5px;font-weight:600;color:var(--g5);letter-spacing:.3px;text-align:center;margin-top:2px;}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   BID PAGE — FULL PAGE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
#pg-bid{display:none;min-height:100vh;background:var(--off);}
#pg-bid.on{display:block;}
.bid-page-hero{background:linear-gradient(135deg,var(--n) 0%,#1a2d4a 100%);padding:52px 0 44px;position:relative;overflow:hidden;}
.bid-page-hero::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");}
.bid-page-hero-inner{position:relative;z-index:1;}
.bid-page-back{display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.5);font-size:13px;cursor:pointer;margin-bottom:20px;transition:color .15s;}
.bid-page-back:hover{color:#fff;}
.bid-page-title{font-family:'Lora',serif;font-size:36px;font-weight:600;color:#fff;margin-bottom:10px;}
.bid-page-sub{font-size:15px;color:rgba(255,255,255,.6);max-width:580px;line-height:1.7;}
.bid-how-steps{display:flex;gap:0;margin-top:28px;flex-wrap:wrap;}
.bid-how-step{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 16px;margin-right:10px;margin-bottom:10px;}
.bid-how-step-num{width:24px;height:24px;background:var(--s);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff;flex-shrink:0;}
.bid-how-step-text{font-size:12.5px;color:rgba(255,255,255,.7);font-weight:500;}
/* Type selector */
.bid-home-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}
.bid-type-selector{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px;}
.bid-type-card{background:#fff;border:2px solid var(--g2);border-radius:var(--r2);padding:20px 16px;cursor:pointer;transition:all .2s;text-align:center;position:relative;overflow:hidden;}
.bid-type-card:hover{border-color:var(--s);transform:translateY(-2px);box-shadow:var(--sh2);}
.bid-type-card.active{border-color:var(--s);box-shadow:0 0 0 3px rgba(232,101,26,.12);}
.bid-type-card.active::before{content:'✓';position:absolute;top:8px;right:10px;font-size:13px;font-weight:800;color:var(--s);}
.bid-type-icon{font-size:32px;margin-bottom:10px;}
.bid-type-name{font-size:15px;font-weight:700;color:var(--n);margin-bottom:5px;}
.bid-type-desc{font-size:13px;color:var(--g4);line-height:1.5;}
.bid-type-badge{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;margin-top:6px;}
.bid-type-badge.green{background:#F0FDF4;color:var(--ok);}
.bid-type-badge.blue{background:#EFF6FF;color:#1D4ED8;}
/* Form body */
.bid-page-body{max-width:860px;margin:0 auto;padding:36px 0 60px;}
.bid-form-card{background:#fff;border-radius:var(--r2);border:var(--border);box-shadow:var(--sh1);padding:32px 36px;margin-bottom:20px;}
.bid-form-card-title{font-size:14px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--g4);margin-bottom:20px;display:flex;align-items:center;gap:8px;}
.bid-form-card-title span{width:6px;height:6px;background:var(--s);border-radius:50%;display:inline-block;}
/* Q category selector */
.qcat-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;}
.qcat-card{border:1.5px solid var(--g2);border-radius:10px;padding:16px;cursor:pointer;transition:all .18s;}
.qcat-card:hover{border-color:var(--s);}
.qcat-card.selected{border-color:var(--s);background:var(--sp);}
.qcat-label{font-size:14.5px;font-weight:700;color:var(--n);margin-bottom:4px;}
.qcat-desc{font-size:12.5px;color:var(--g4);line-height:1.5;}
.qcat-card.disabled{opacity:.4;cursor:not-allowed;pointer-events:none;}
/* Disclaimer */
.bid-disclaimer{background:linear-gradient(135deg,#FFF7ED,#FFFBEB);border:1px solid #FED7AA;border-radius:10px;padding:16px 20px;font-size:13.5px;color:#92400E;line-height:1.6;}
.bid-disclaimer-title{font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:6px;}
/* Product rows */
.bid-product-list{margin-bottom:12px;}
.bid-product-row{display:grid;grid-template-columns:1fr 80px 100px 36px;gap:10px;align-items:start;margin-bottom:10px;}
.bid-product-row input,.bid-product-row select{border:var(--border);border-radius:8px;padding:12px 14px;font-size:14.5px;outline:none;font-family:'Plus Jakarta Sans',sans-serif;width:100%;}
.bid-product-row input:focus,.bid-product-row select:focus{border-color:var(--s);}
.bid-product-del{background:none;border:1.5px solid var(--g2);border-radius:8px;width:40px;height:44px;cursor:pointer;font-size:15px;color:var(--g4);display:flex;align-items:center;justify-content:center;transition:all .15s;padding:0;}
.bid-product-del:hover{border-color:var(--err);color:var(--err);}
.bid-add-row-btn{display:flex;align-items:center;gap:8px;background:none;border:1.5px dashed var(--g2);border-radius:9px;padding:12px 18px;font-size:14.5px;font-weight:600;color:var(--g4);cursor:pointer;width:100%;transition:all .15s;font-family:'Plus Jakarta Sans',sans-serif;}
.bid-add-row-btn:hover{border-color:var(--s);color:var(--s);}
/* Success state */
.bid-success{text-align:center;padding:48px 24px;}
.bid-success-icon{font-size:56px;margin-bottom:16px;}
.bid-success-title{font-family:'Lora',serif;font-size:24px;color:var(--n);margin-bottom:8px;}
.bid-success-sub{font-size:14px;color:var(--g5);line-height:1.6;max-width:400px;margin:0 auto 24px;}
/* Upload */
.bid-upload-area{border:2px dashed var(--g2);border-radius:10px;padding:16px;text-align:center;cursor:pointer;transition:border-color .15s;font-size:13px;color:var(--g4);}
.bid-upload-area:hover{border-color:var(--s);color:var(--s);}
.bid-upload-area input{display:none;}
.bid-file-list{margin-top:8px;display:flex;flex-wrap:wrap;gap:6px;}
.bid-file-chip{display:flex;align-items:center;gap:6px;background:var(--g1);border:var(--border);border-radius:6px;padding:4px 10px;font-size:12px;color:var(--n);}
.bid-file-chip button{background:none;border:none;cursor:pointer;color:var(--g4);font-size:12px;padding:0;line-height:1;}
/* ━━ PROCUREMENT GUIDE PAGE ━━ */

/* ── TOPBAR NOTICE ── */
.topbar{background:var(--n);color:rgba(255,255,255,.7);padding:10px 0;font-size:13px;text-align:center;}
.topbar strong{color:#fff;}

/* ── HERO ── */
.hero{background:linear-gradient(135deg,var(--n) 0%,#1a2d4a 100%);padding:72px 0 64px;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle at 80% 50%,rgba(232,101,26,.12) 0%,transparent 60%),radial-gradient(circle at 20% 80%,rgba(19,136,8,.08) 0%,transparent 50%);pointer-events:none;}
.hero-inner{position:relative;z-index:1;}
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(232,101,26,.15);border:1px solid rgba(232,101,26,.3);color:var(--s2);font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:6px 14px;border-radius:20px;margin-bottom:24px;}
.hero h1{font-family:'Lora',serif;font-size:52px;color:#fff;line-height:1.1;margin-bottom:18px;max-width:680px;}
.hero h1 em{color:var(--s2);font-style:italic;}
.hero-lead{font-size:17px;color:rgba(255,255,255,.65);max-width:580px;line-height:1.85;margin-bottom:36px;}
.hero-pills{display:flex;gap:10px;flex-wrap:wrap;}
.hero-pill{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:8px;padding:9px 16px;font-size:13px;color:rgba(255,255,255,.8);font-weight:500;}
.hero-pill span{font-size:15px;}

/* ── ROUTE FINDER ── */
.finder{padding:72px 0;background:var(--off);}
.finder-head{text-align:center;margin-bottom:52px;}
.step-label{display:inline-flex;align-items:center;gap:10px;margin-bottom:14px;}
.step-num{width:32px;height:32px;border-radius:50%;background:var(--s);color:#fff;font-size:14px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.step-title{font-family:'Lora',serif;font-size:32px;color:var(--n);}
.step-sub{font-size:16px;color:var(--g5);margin-top:8px;}

/* Route cards — step 1 */
.route-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.route-card{background:#fff;border:2px solid var(--g2);border-radius:var(--r3);padding:32px 28px;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;display:flex;flex-direction:column;}
.route-card-inner{flex:1;}
.route-card::before{content:'';position:absolute;inset:0;background:var(--sp);opacity:0;transition:opacity .22s;}
.route-card:hover{border-color:var(--s);transform:translateY(-3px);box-shadow:var(--sh3);}
.route-card:hover::before{opacity:1;}
.route-card.selected{border-color:var(--s);box-shadow:0 0 0 4px rgba(232,101,26,.12);transform:translateY(-3px);}
.route-card.selected::before{opacity:1;}
.route-card-inner{position:relative;z-index:1;}
.route-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:18px;}
.route-icon.orange{background:var(--sp);}
.route-icon.blue{background:#EEF2FF;}
.route-icon.amber{background:#FFFBEB;}
.route-name{font-family:'Lora',serif;font-size:20px;color:var(--n);margin-bottom:8px;font-weight:600;}
.route-desc{font-size:14px;color:var(--g5);line-height:1.75;margin-bottom:16px;}
.route-when{background:var(--g1);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--g6);line-height:1.6;}
.route-when strong{color:var(--n);display:block;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--s);margin-bottom:4px;}
.route-check{position:absolute;top:16px;right:16px;width:26px;height:26px;border-radius:50%;background:var(--s);color:#fff;font-size:13px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;z-index:2;}
.route-card.selected .route-check{opacity:1;}
/* Catalogue note inside direct purchase card */
.cat-note{margin-top:14px;padding:10px 14px;background:#EFF6FF;border-radius:8px;border-left:3px solid #3B82F6;font-size:13px;color:#1E40AF;line-height:1.6;}
.cat-note strong{display:block;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#2563EB;margin-bottom:3px;}

/* Step 2 — supply cards */
.supply-section{margin-top:52px;padding-top:52px;border-top:2px dashed var(--g2);animation:fadeSlide .35s ease;}
@keyframes fadeSlide{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.supply-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.supply-card{background:#fff;border:2px solid var(--g2);border-radius:var(--r3);padding:28px 24px;cursor:pointer;transition:all .22s;position:relative;}
.supply-card:hover{border-color:var(--n);transform:translateY(-2px);box-shadow:var(--sh2);}
.supply-card.selected{border-color:var(--n);box-shadow:0 0 0 4px rgba(11,29,53,.1);transform:translateY(-2px);}
.supply-icon{font-size:32px;margin-bottom:14px;}
.supply-name{font-family:'Lora',serif;font-size:18px;color:var(--n);margin-bottom:6px;font-weight:600;}
.supply-desc{font-size:13.5px;color:var(--g5);line-height:1.7;margin-bottom:12px;}
.supply-meta{display:flex;gap:8px;flex-wrap:wrap;}
.supply-tag{font-size:11.5px;font-weight:700;padding:3px 10px;border-radius:20px;}
.supply-tag.speed{background:#F0FDF4;color:#15803D;}
.supply-tag.docs{background:#EEF2FF;color:var(--n2);}
.supply-check{position:absolute;top:14px;right:14px;width:24px;height:24px;border-radius:50%;background:var(--n);color:#fff;font-size:12px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;}
.supply-card.selected .supply-check{opacity:1;}

/* CTA after both selected */
.finder-cta{margin-top:40px;text-align:center;animation:fadeSlide .3s ease;}
.finder-cta-btn{display:inline-flex;align-items:center;gap:10px;background:var(--s);color:#fff;padding:16px 36px;border-radius:12px;font-size:17px;font-weight:700;border:none;cursor:pointer;transition:all .2s;box-shadow:0 4px 20px rgba(232,101,26,.35);}
.finder-cta-btn:hover{background:var(--s2);transform:translateY(-2px);box-shadow:0 6px 28px rgba(232,101,26,.45);}
.finder-cta-hint{font-size:13px;color:var(--g4);margin-top:10px;}

/* ── MODAL ── */
/* ── MODAL (procurement guide only) ── */
#procguide-modal-bg{position:fixed;inset:0;background:rgba(11,29,53,.6);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .25s;}
#procguide-modal-bg.open{opacity:1;pointer-events:all;}
#procguide-modal-bg .modal{background:#fff;border-radius:var(--r3);max-width:620px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.25);transform:translateY(20px);transition:transform .25s;}
#procguide-modal-bg.open .modal{transform:translateY(0);}
.modal-hero{padding:32px 36px 24px;border-bottom:var(--border);}
.modal-route-tags{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;}
.modal-route-tag{font-size:11.5px;font-weight:700;padding:4px 12px;border-radius:20px;letter-spacing:.5px;}
.modal-route-tag.procurement{background:var(--sp);color:var(--s);}
.modal-route-tag.supply{background:#EEF2FF;color:var(--n2);}
.modal-title{font-family:'Lora',serif;font-size:26px;color:var(--n);margin-bottom:8px;line-height:1.2;}
.modal-subtitle{font-size:14.5px;color:var(--g5);line-height:1.7;}
.modal-body{padding:28px 36px;}
.modal-steps{display:flex;flex-direction:column;gap:0;margin-bottom:28px;}
.modal-step{display:flex;gap:0;align-items:stretch;}
.modal-step-left{display:flex;flex-direction:column;align-items:center;width:44px;flex-shrink:0;}
.modal-step-num{width:32px;height:32px;border-radius:50%;background:var(--n);color:#fff;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.modal-step-num.done{background:var(--g);}
.modal-step-line{width:2px;flex:1;background:var(--g2);margin:4px 0;}
.modal-step-content{padding:0 0 24px 14px;}
.modal-step-title{font-size:15px;font-weight:700;color:var(--n);margin-bottom:4px;margin-top:5px;}
.modal-step-desc{font-size:13.5px;color:var(--g5);line-height:1.7;}
.modal-docs{background:var(--off);border-radius:var(--r);padding:16px 20px;margin-bottom:24px;}
.modal-docs-title{font-size:11px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--g4);margin-bottom:10px;}
.modal-docs-list{display:flex;flex-wrap:wrap;gap:8px;}
.modal-doc-chip{font-size:12.5px;font-weight:600;padding:4px 12px;border-radius:6px;background:#fff;border:var(--border);color:var(--n);}
.modal-timeline{display:flex;gap:12px;margin-bottom:28px;flex-wrap:wrap;}
.modal-tl{flex:1;min-width:120px;background:var(--off);border-radius:var(--r);padding:12px 16px;text-align:center;}
.modal-tl-val{font-size:18px;font-weight:800;color:var(--n);font-family:'Lora',serif;}
.modal-tl-label{font-size:11px;color:var(--g4);margin-top:2px;}
.modal-actions{display:flex;gap:10px;flex-wrap:wrap;}
.modal-btn-primary{flex:1;padding:13px 20px;background:var(--s);color:#fff;border-radius:var(--r);font-size:15px;font-weight:700;border:none;cursor:pointer;transition:background .15s;display:flex;align-items:center;justify-content:center;gap:8px;}
.modal-btn-primary:hover{background:var(--s2);}
.modal-btn-wa{flex:1;padding:13px 20px;background:#25D366;color:#fff;border-radius:var(--r);font-size:15px;font-weight:700;border:none;cursor:pointer;transition:background .15s;display:flex;align-items:center;justify-content:center;gap:8px;}
.modal-btn-wa:hover{background:#1ebe5e;}
.modal-close-row{padding:16px 36px 24px;border-top:var(--border);text-align:center;}
.modal-close-btn{background:none;border:none;color:var(--g4);font-size:14px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;}
.modal-close-btn:hover{color:var(--n);}

/* ── LEARN SECTION ── */
.learn{padding:80px 0;background:#fff;}
.learn-head{text-align:center;margin-bottom:56px;}
.learn-tag{font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--s);margin-bottom:10px;}
.learn-title{font-family:'Lora',serif;font-size:40px;color:var(--n);margin-bottom:14px;}
.learn-sub{font-size:16px;color:var(--g5);max-width:560px;margin:0 auto;}
.learn-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.learn-card{border:var(--border);border-radius:var(--r2);overflow:hidden;background:#fff;transition:box-shadow .18s;}
.learn-card:hover{box-shadow:var(--sh2);}
.learn-card-head{padding:20px 24px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;}
.learn-card-left{display:flex;align-items:center;gap:14px;}
.learn-card-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.learn-card-title{font-size:15.5px;font-weight:700;color:var(--n);}
.learn-card-peek{font-size:13px;color:var(--g4);margin-top:2px;}
.learn-card-arrow{font-size:18px;color:var(--g4);transition:transform .2s;flex-shrink:0;}
.learn-card.open .learn-card-arrow{transform:rotate(90deg);}
.learn-card-body{display:none;padding:0 24px 24px;font-size:14.5px;color:var(--g5);line-height:1.85;border-top:var(--border);}
.learn-card.open .learn-card-body{display:block;}
.learn-card-body p{margin-bottom:14px;}
.learn-card-body p:last-child{margin-bottom:0;}
.learn-card-body strong{color:var(--n);}
.learn-card-body .callout{background:var(--off);border-left:3px solid var(--s);border-radius:0 var(--r) var(--r) 0;padding:12px 16px;margin:14px 0;font-size:13.5px;}
.learn-card-body .example-table{width:100%;border-collapse:collapse;margin:14px 0;font-size:13.5px;}
.learn-card-body .example-table th{background:var(--n);color:#fff;padding:10px 14px;text-align:left;font-weight:600;}
.learn-card-body .example-table td{padding:9px 14px;border-bottom:1px solid var(--g2);}
.learn-card-body .example-table tr:last-child td{border-bottom:none;}
.learn-card-body .example-table tr:nth-child(even) td{background:var(--off);}

/* ── COMPARISON TABLE ── */
.compare-section{padding:72px 0;background:var(--off);}
.compare-head{text-align:center;margin-bottom:40px;}
.compare-table{width:100%;border-collapse:collapse;font-size:14.5px;background:#fff;border-radius:var(--r2);overflow:hidden;box-shadow:var(--sh1);}
.compare-table th{padding:14px 18px;text-align:left;font-weight:700;font-size:12px;letter-spacing:.5px;text-transform:uppercase;color:var(--g5);background:var(--g1);border-bottom:2px solid var(--g2);}
.compare-table td{padding:13px 18px;border-bottom:1px solid var(--g2);vertical-align:middle;}
.compare-table tr:last-child td{border-bottom:none;}
.compare-table tr:hover td{background:var(--sp);}
.yes{color:var(--g);font-weight:700;}
.no{color:var(--g3);font-weight:600;}
.pill{display:inline-block;font-size:12px;font-weight:700;padding:3px 10px;border-radius:20px;}
.pill.green{background:#F0FDF4;color:#15803D;}
.pill.amber{background:#FFFBEB;color:#92400E;}
.pill.blue{background:#EEF2FF;color:var(--n2);}

/* ── CTA BAND ── */
.cta-band{background:linear-gradient(135deg,var(--n),#1a2d4a);padding:64px 0;}
.cta-inner{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.cta-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--r2);padding:28px 24px;text-align:center;transition:all .2s;}
.cta-card:hover{background:rgba(255,255,255,.1);transform:translateY(-2px);}
.cta-card-icon{font-size:32px;margin-bottom:14px;}
.cta-card-title{font-family:'Lora',serif;font-size:20px;color:#fff;margin-bottom:8px;}
.cta-card-desc{font-size:13.5px;color:rgba(255,255,255,.6);line-height:1.7;margin-bottom:20px;}
.cta-card-btn{display:inline-flex;align-items:center;gap:7px;padding:11px 22px;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;border:none;font-family:'Plus Jakarta Sans',sans-serif;transition:all .15s;}
.cta-card-btn.orange{background:var(--s);color:#fff;}
.cta-card-btn.orange:hover{background:var(--s2);}
.cta-card-btn.navy{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:#fff;}
.cta-card-btn.navy:hover{background:rgba(255,255,255,.25);}
.cta-card-btn.amber{background:#FCD34D;color:#78350F;}
.cta-card-btn.amber:hover{background:#FDE68A;}

/* Responsive */
@media(max-width:900px){
  .wrap{padding:0 28px;}
  .hero h1{font-size:38px;}
  .route-grid,.supply-grid,.cta-inner{grid-template-columns:1fr;}
  .learn-grid{grid-template-columns:1fr;}
  .modal{margin:0;border-radius:var(--r2) var(--r2) 0 0;max-height:85vh;}
  #procguide-modal-bg{align-items:flex-end;padding:0;}
@media(max-width:600px){
  .wrap{padding:0 18px;}
  .hero{padding:48px 0 44px;}
  .hero h1{font-size:30px;}

/* Bid page responsive styles removed for desktop-first layout */

/* ━━ BID SUBMIT BAR ━━ */
.bid-submit-bar{
  background:#fff;border-radius:var(--r2);border:var(--border);
  padding:20px 28px;display:flex;align-items:center;
  gap:16px;box-shadow:var(--sh1);flex-wrap:wrap;
}
.bid-submit-primary{order:3;flex-shrink:0;}
.bid-submit-btn{padding:13px 32px;font-size:16px;}
.bid-submit-meta{order:1;flex:1;min-width:180px;}
.bid-submit-secondary{order:2;display:flex;gap:8px;flex-shrink:0;}

@media(max-width:600px){
  .bid-submit-bar{flex-direction:column;align-items:stretch;padding:18px;}
  .bid-submit-meta{order:1;text-align:center;}
  .bid-submit-primary{order:2;width:100%;}
  .bid-submit-btn{width:100%;justify-content:center;display:flex;}
  .bid-submit-secondary{order:3;justify-content:center;}
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   REQUEST TRACKING SYSTEM v2
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

/* ── Toolbar ── */
.req-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.req-search-wrap{flex:1;min-width:180px;position:relative;}
.req-search-wrap svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:14px;height:14px;fill:var(--g4);pointer-events:none;}
.req-search-inp{width:100%;border:var(--border);border-radius:8px;padding:9px 12px 9px 32px;font-size:13.5px;font-family:'Plus Jakarta Sans',sans-serif;outline:none;color:var(--g6);background:#fff;transition:border-color .15s;}
.req-search-inp:focus{border-color:var(--s);}
.req-filter-tabs{display:flex;gap:4px;flex-wrap:wrap;}
.req-tab{padding:7px 13px;border-radius:7px;font-size:12.5px;font-weight:600;border:var(--border);background:#fff;color:var(--g5);cursor:pointer;transition:all .15s;font-family:'Plus Jakarta Sans',sans-serif;white-space:nowrap;}
.req-tab.on{background:var(--n);color:#fff;border-color:var(--n);}
.req-tab:hover:not(.on){border-color:var(--s);color:var(--s);}
.req-sort-sel{border:var(--border);border-radius:8px;padding:8px 10px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif;color:var(--g6);background:#fff;outline:none;cursor:pointer;}

/* ── Request Cards ── */
.req-card{background:#fff;border:1.5px solid var(--g2);border-radius:var(--r2);overflow:hidden;margin-bottom:10px;transition:all .18s;cursor:pointer;}
.req-card:hover{border-color:var(--s);box-shadow:0 4px 16px rgba(232,101,26,.1);}
.req-card-header{padding:16px 18px 12px;display:flex;align-items:flex-start;gap:12px;}
.req-card-icon{width:40px;height:40px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.req-card-icon.type-product{background:#EEF2FF;}
.req-card-icon.type-bid{background:#FEF3EB;}
.req-card-icon.type-quotation{background:#F0FDF4;}
.req-card-icon.type-enquiry{background:#FFF7ED;}
.req-card-icon.type-amazon{background:#FFF8E1;}
.req-card-main{flex:1;min-width:0;}
.req-card-title{font-size:14px;font-weight:700;color:var(--n);line-height:1.3;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.req-card-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.req-card-date{font-size:11.5px;color:var(--g4);}
.req-card-type{font-size:11px;font-weight:700;letter-spacing:.5px;padding:2px 8px;border-radius:20px;text-transform:uppercase;}
.req-type-product{background:#EEF2FF;color:#4338CA;}
.req-type-bid{background:#FEF3EB;color:#C2410C;}
.req-type-quotation{background:#F0FDF4;color:#15803D;}
.req-type-enquiry{background:#FFF7ED;color:#92400E;}
.req-type-amazon{background:#FFF8E1;color:#92400E;}
.req-card-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;}

/* ── Status badges ── */
.req-badge{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:700;padding:4px 10px;border-radius:20px;white-space:nowrap;}
.req-badge::before{content:'';width:6px;height:6px;border-radius:50%;display:inline-block;flex-shrink:0;}
.req-badge.pending{background:#FEF9C3;color:#854D0E;}
.req-badge.pending::before{background:#EAB308;}
.req-badge.active{background:#DBEAFE;color:#1D4ED8;}
.req-badge.active::before{background:#3B82F6;animation:pulse-dot 1.5s ease-in-out infinite;}
.req-badge.done{background:#DCFCE7;color:#15803D;}
.req-badge.done::before{background:#22C55E;}
.req-badge.cancelled{background:var(--g1);color:var(--g4);}
.req-badge.cancelled::before{background:var(--g3);}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:.4;}}

/* ── Card body (collapsed details) ── */
.req-card-body{border-top:1px solid var(--g2);padding:12px 18px;background:var(--off);}
.req-card-detail-row{display:flex;gap:6px;margin-bottom:6px;font-size:13px;color:var(--g5);line-height:1.5;}
.req-card-detail-row strong{color:var(--n);font-weight:600;flex-shrink:0;}

/* ── Progress timeline ── */
.req-timeline{display:flex;gap:0;margin:14px 0 10px;position:relative;}
.req-tl-step{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;}
.req-tl-step:not(:last-child)::after{content:'';position:absolute;top:11px;left:50%;width:100%;height:2px;background:var(--g2);z-index:0;}
.req-tl-step.done-step:not(:last-child)::after{background:var(--ok);}
.req-tl-dot{width:22px;height:22px;border-radius:50%;border:2px solid var(--g2);background:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;position:relative;z-index:1;transition:all .2s;}
.req-tl-step.done-step .req-tl-dot{background:var(--ok);border-color:var(--ok);color:#fff;}
.req-tl-step.current-step .req-tl-dot{background:var(--s);border-color:var(--s);color:#fff;box-shadow:0 0 0 4px rgba(232,101,26,.2);}
.req-tl-label{font-size:10px;font-weight:600;color:var(--g4);text-align:center;margin-top:5px;line-height:1.3;padding:0 2px;}
.req-tl-step.done-step .req-tl-label{color:var(--ok);}
.req-tl-step.current-step .req-tl-label{color:var(--s);font-weight:700;}

/* ── Card actions row ── */
.req-card-actions{display:flex;align-items:center;justify-content:space-between;padding:10px 18px 14px;gap:10px;}
.req-card-btn{padding:7px 14px;border-radius:7px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:all .15s;border:var(--border);background:#fff;color:var(--n);}
.req-card-btn:hover{border-color:var(--s);color:var(--s);}
.req-card-btn.danger{color:var(--err);border-color:rgba(220,38,38,.25);}
.req-card-btn.danger:hover{background:rgba(220,38,38,.06);}
.req-card-qty-budget{font-size:12px;color:var(--g4);display:flex;gap:12px;}
.req-card-qty-budget span strong{color:var(--g6);}

/* ── Empty / no results ── */
.req-empty{text-align:center;padding:52px 24px;}
.req-empty-icon{font-size:52px;margin-bottom:14px;opacity:.5;}
.req-empty-h{font-size:15px;font-weight:700;color:var(--n);margin-bottom:6px;}
.req-empty-p{font-size:13.5px;color:var(--g4);margin-bottom:20px;}

/* ── Stats summary bar ── */
.req-stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px;}
.req-stat-chip{background:#fff;border:var(--border);border-radius:var(--r);padding:12px 14px;text-align:center;}
.req-stat-chip-n{font-size:22px;font-weight:800;color:var(--n);line-height:1;}
.req-stat-chip-l{font-size:11px;font-weight:600;color:var(--g4);margin-top:3px;text-transform:uppercase;letter-spacing:.5px;}
.req-stat-chip.chip-active .req-stat-chip-n{color:var(--s);}
.req-stat-chip.chip-done .req-stat-chip-n{color:var(--ok);}
.req-stat-chip.chip-pending .req-stat-chip-n{color:#EAB308;}

/* ── Detail Modal ── */
#req-detail-modal{position:fixed;inset:0;z-index:2000;display:flex;align-items:center;justify-content:center;padding:20px;}
#req-detail-modal.hidden{display:none;}
.rdm-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.45);}
.rdm-card{position:relative;background:#fff;border-radius:var(--r3);width:100%;max-width:600px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.18);display:flex;flex-direction:column;}
.rdm-head{padding:22px 24px 16px;border-bottom:1px solid var(--g2);display:flex;align-items:flex-start;gap:14px;position:sticky;top:0;background:#fff;z-index:10;}
.rdm-head-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.rdm-head-text{flex:1;min-width:0;}
.rdm-head-title{font-family:'Lora',serif;font-size:18px;color:var(--n);font-weight:600;line-height:1.25;margin-bottom:4px;}
.rdm-head-sub{font-size:12px;color:var(--g4);}
.rdm-close{width:34px;height:34px;background:var(--g1);border:none;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--g5);font-family:'Plus Jakarta Sans',sans-serif;}
.rdm-close:hover{background:var(--g2);}
.rdm-body{padding:20px 24px;}
.rdm-section{margin-bottom:20px;}
.rdm-section-title{font-size:10.5px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--g4);margin-bottom:10px;}
.rdm-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.rdm-info-item{background:var(--off);border-radius:8px;padding:10px 12px;}
.rdm-info-item label{font-size:10.5px;font-weight:700;color:var(--g4);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:3px;}
.rdm-info-item span{font-size:13.5px;font-weight:600;color:var(--n);}
.rdm-extra-text{font-size:13px;color:var(--g5);line-height:1.7;background:var(--off);border-radius:8px;padding:12px 14px;}
.rdm-tl{display:flex;flex-direction:column;gap:0;}
.rdm-tl-item{display:flex;gap:12px;position:relative;}
.rdm-tl-item:not(:last-child)::before{content:'';position:absolute;left:11px;top:24px;bottom:-2px;width:2px;background:var(--g2);}
.rdm-tl-item.done-tl::before{background:var(--ok);}
.rdm-tl-dot2{width:24px;height:24px;border-radius:50%;border:2px solid var(--g2);background:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;margin-top:2px;}
.rdm-tl-item.done-tl .rdm-tl-dot2{background:var(--ok);border-color:var(--ok);color:#fff;}
.rdm-tl-item.current-tl .rdm-tl-dot2{background:var(--s);border-color:var(--s);color:#fff;box-shadow:0 0 0 4px rgba(232,101,26,.2);}
.rdm-tl-item.future-tl .rdm-tl-dot2{background:#fff;border-color:var(--g2);color:var(--g4);}
.rdm-tl-content{flex:1;padding-bottom:16px;}
.rdm-tl-label{font-size:13.5px;font-weight:700;color:var(--n);margin-bottom:2px;}
.rdm-tl-item.future-tl .rdm-tl-label{color:var(--g4);}
.rdm-tl-desc{font-size:12px;color:var(--g5);line-height:1.5;}
.rdm-tl-time{font-size:11px;color:var(--g3);margin-top:2px;}
.rdm-footer{padding:16px 24px;border-top:1px solid var(--g2);display:flex;gap:10px;position:sticky;bottom:0;background:#fff;}
.rdm-footer .btn{flex:1;justify-content:center;}

/* Responsive */
@media(max-width:680px){
  .req-stats-bar{grid-template-columns:repeat(2,1fr);}
  .rdm-info-grid{grid-template-columns:1fr;}
  .req-timeline{display:none;}
  .rdm-card{border-radius:var(--r2);}
}

/* TRACKING SYSTEM - PUBLIC TRACK PAGE */
.track-wrap{background:var(--off);min-height:70vh;}
.track-hero{background:linear-gradient(135deg,var(--n),var(--n2));padding:52px 0 44px;}
.track-hero-h{font-family:'Lora',serif;font-size:34px;color:#fff;margin-bottom:8px;}
.track-hero-sub{font-size:15px;color:rgba(255,255,255,.65);margin-bottom:28px;}
.track-box{display:flex;gap:8px;max-width:500px;}
.track-box input{flex:1;border:none;border-radius:10px;padding:13px 16px;font-size:15px;font-family:'Plus Jakarta Sans',sans-serif;outline:none;color:var(--g6);letter-spacing:1px;}
.track-box button{background:var(--s);color:#fff;border:none;border-radius:10px;padding:13px 22px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;white-space:nowrap;transition:background .15s;}
.track-box button:hover{background:var(--s2);}
.track-hero-hint{font-size:12px;color:rgba(255,255,255,.4);margin-top:8px;}
.track-result-wrap{max-width:620px;margin:36px auto;padding:0 20px 48px;}
.track-card{background:#fff;border-radius:var(--r2);box-shadow:var(--sh2);overflow:hidden;margin-bottom:16px;}
.track-card-top{background:var(--n);padding:18px 22px;display:flex;align-items:center;gap:12px;}
.track-card-icon{font-size:26px;flex-shrink:0;}
.track-card-info{flex:1;min-width:0;}
.track-card-prod{font-size:14px;font-weight:700;color:#fff;word-break:break-word;margin-bottom:2px;}
.track-card-date{font-size:11.5px;color:rgba(255,255,255,.5);}
.track-card-id{background:var(--s);color:#fff;font-size:12px;font-weight:800;padding:5px 12px;border-radius:6px;letter-spacing:1px;font-family:monospace;white-space:nowrap;flex-shrink:0;}
.track-card-body{padding:18px 22px;}
.track-status-row{display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.track-steps-wrap{margin-bottom:16px;}
.track-steps-label{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--g4);margin-bottom:10px;}
.track-steps{display:flex;}
.track-step{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;}
.track-step:not(:last-child)::after{content:'';position:absolute;top:13px;left:50%;width:100%;height:2px;background:var(--g2);z-index:0;}
.track-step.ts-done:not(:last-child)::after,.track-step.ts-cur:not(:last-child)::after{background:var(--ok);}
.track-step.ts-cur:not(:last-child)::after{background:linear-gradient(90deg,var(--ok),var(--g2));}
.track-dot{width:26px;height:26px;border-radius:50%;border:2px solid var(--g2);background:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;z-index:1;position:relative;}
.track-step.ts-done .track-dot{background:var(--ok);border-color:var(--ok);color:#fff;}
.track-step.ts-cur .track-dot{background:var(--s);border-color:var(--s);color:#fff;box-shadow:0 0 0 5px rgba(232,101,26,.18);}
.track-step-lbl{font-size:10px;font-weight:600;color:var(--g4);text-align:center;margin-top:5px;line-height:1.3;padding:0 2px;}
.track-step.ts-done .track-step-lbl{color:var(--ok);}
.track-step.ts-cur .track-step-lbl{color:var(--s);font-weight:700;}
.track-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.track-info-item{background:var(--off);border-radius:8px;padding:9px 12px;}
.track-info-item label{font-size:10px;font-weight:700;color:var(--g4);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:2px;}
.track-info-item span{font-size:13px;font-weight:600;color:var(--n);}
.track-wa{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:12px;border-radius:var(--r);background:var(--wa);color:#fff;border:none;font-size:13.5px;font-weight:700;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;}
.track-wa:hover{background:#1ebe5e;}
.track-not-found{text-align:center;padding:48px 24px;background:#fff;border-radius:var(--r2);box-shadow:var(--sh1);}
.track-not-found-icon{font-size:48px;margin-bottom:12px;}
.track-device-list{max-width:620px;margin:0 auto;padding:0 20px 48px;}
.track-device-h{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--g4);margin-bottom:12px;}
.track-device-item{background:#fff;border:var(--border);border-radius:var(--r2);padding:13px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:all .15s;}
.track-device-item:hover{border-color:var(--s);box-shadow:var(--sh1);}
.track-device-icon{font-size:20px;flex-shrink:0;}
.track-device-main{flex:1;min-width:0;}
.track-device-prod{font-size:13.5px;font-weight:700;color:var(--n);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.track-device-meta{font-size:11.5px;color:var(--g4);margin-top:2px;}
.track-id-reveal{background:linear-gradient(135deg,#EEF2FF,#E0E7FF);border:1.5px solid #C7D2FE;border-radius:var(--r2);padding:16px 20px;margin-top:14px;}
.track-id-reveal-label{font-size:10.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#4338CA;margin-bottom:6px;}
.track-id-reveal-code{font-size:22px;font-weight:800;color:var(--n);letter-spacing:2px;font-family:monospace;margin-bottom:6px;}
.track-id-reveal-hint{font-size:12px;color:var(--g5);line-height:1.6;}
.track-id-reveal-copy{background:var(--n);color:#fff;border:none;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;margin-top:8px;transition:background .15s;}
.track-id-reveal-copy:hover{background:var(--n2);}
@media(max-width:600px){
  .track-info-grid{grid-template-columns:1fr;}
  .track-hero-h{font-size:24px;}
  .track-box{flex-direction:column;}
  .track-steps .track-step-lbl{font-size:9px;}
}

/* ── TEAM / FULFILMENT STAFF MANAGEMENT ── */
.team-card{background:#fff;border:var(--border);border-radius:var(--r2);padding:18px 20px;margin-bottom:10px;display:flex;align-items:center;gap:14px;}
.team-avatar{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;color:#fff;flex-shrink:0;}
.team-info{flex:1;min-width:0;}
.team-name{font-size:14px;font-weight:700;color:var(--n);margin-bottom:2px;}
.team-role{font-size:12px;color:var(--g4);}
.team-stats{font-size:11.5px;color:var(--s);font-weight:600;margin-top:2px;}
.team-actions{display:flex;gap:6px;flex-shrink:0;}
.team-btn{padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600;border:var(--border);background:#fff;color:var(--g5);cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:all .12s;}
.team-btn:hover{border-color:var(--s);color:var(--s);}
.team-btn.danger{color:var(--err);border-color:rgba(220,38,38,.25);}
.team-btn.danger:hover{background:rgba(220,38,38,.06);}
.team-add-form{background:var(--off);border:var(--border);border-radius:var(--r2);padding:18px 20px;margin-bottom:16px;}
.team-add-form .afg{margin-bottom:12px;}
.assign-badge{display:inline-flex;align-items:center;gap:5px;background:#EEF2FF;color:#4338CA;font-size:11px;font-weight:700;padding:3px 9px;border-radius:20px;}
.assign-badge-none{color:var(--g3);font-size:12px;}
/* Tracking page — assigned staff badge */
.track-assigned{display:flex;align-items:center;gap:8px;background:var(--off);border-radius:8px;padding:10px 14px;margin-bottom:12px;}
.track-assigned-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.track-assigned-text{font-size:13px;color:var(--g6);}
.track-assigned-text strong{color:var(--n);}

/* ── Amazon Cart / Request inline details form ── */
.amz-action-form{background:#fff;border:1.5px solid var(--s);border-radius:var(--r2);padding:16px;margin-top:10px;animation:fadeSlide .2s ease;}
.amz-action-form-title{font-size:12px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--s);margin-bottom:12px;}
.amz-action-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
.amz-action-form .fg{display:flex;flex-direction:column;gap:4px;}
.amz-action-form label{font-size:11.5px;font-weight:700;color:var(--g5);}
.amz-action-form input{border:var(--border);border-radius:7px;padding:8px 11px;font-size:13.5px;font-family:'Plus Jakarta Sans',sans-serif;outline:none;width:100%;box-sizing:border-box;transition:border-color .15s;}
.amz-action-form input:focus{border-color:var(--s);}
.amz-qty-row{display:flex;align-items:center;gap:0;border:var(--border);border-radius:7px;overflow:hidden;height:36px;}
