.faq-item.open .faq-icon{background:var(--s);border-color:var(--s);color:#fff;transform:rotate(45deg);}
.faq-item.open .faq-q{color:var(--s);}
.faq-a{font-size:14px;color:var(--g5);line-height:1.8;padding:0 4px 16px;display:none;}
.faq-item.open .faq-a{display:block;}

/* ━━━━━━━━━━━━━━━━━━ USER AUTH PAGES ━━━━━━━━━━━━━━━━━━ */
.auth-wrap{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;background:#fff;}
.auth-left{background:linear-gradient(135deg,var(--n) 0%,var(--n2) 100%);padding:60px 52px;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden;}
.auth-left::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 70%,rgba(232,101,26,.18) 0%,transparent 60%);pointer-events:none;}
.auth-left-inner{position:relative;z-index:1;}
.auth-brand{display:flex;align-items:center;gap:10px;margin-bottom:52px;cursor:pointer;}
.auth-brand-name{font-size:20px;font-weight:700;color:#fff;}
.auth-left-h{font-family:'Lora',serif;font-size:32px;color:#fff;line-height:1.2;margin-bottom:14px;}
.auth-left-h em{color:var(--gold);font-style:italic;}
.auth-left-p{font-size:14.5px;color:rgba(255,255,255,.6);line-height:1.8;margin-bottom:36px;}
.auth-features{display:flex;flex-direction:column;gap:14px;}
.auth-feat{display:flex;align-items:center;gap:12px;font-size:14px;color:rgba(255,255,255,.75);}
.auth-feat-dot{width:8px;height:8px;border-radius:50%;background:var(--s);flex-shrink:0;}
.auth-left-foot{font-size:12px;color:rgba(255,255,255,.3);position:relative;z-index:1;}
.auth-right{display:flex;align-items:center;justify-content:center;padding:60px 52px;background:var(--off);}
.auth-form-box{width:100%;max-width:400px;}
.auth-form-card{width:100%;max-width:440px;background:#fff;border-radius:var(--r3);border:var(--border);box-shadow:var(--sh2);padding:36px 36px 28px;}
.auth-tab-row{display:flex;gap:0;background:var(--g1);border-radius:var(--r);padding:4px;margin-bottom:32px;}
.auth-tab{flex:1;padding:10px;text-align:center;border-radius:7px;font-size:14px;font-weight:600;cursor:pointer;color:var(--g4);transition:all .18s;}
.auth-tab.on{background:#fff;color:var(--n);box-shadow:var(--sh1);}
.auth-form-h{font-family:'Lora',serif;font-size:26px;color:var(--n);margin-bottom:6px;}
.auth-form-sub{font-size:13.5px;color:var(--g4);margin-bottom:28px;line-height:1.6;}
.auth-fg{display:flex;flex-direction:column;gap:5px;margin-bottom:16px;}
.auth-fg label{font-size:13px;font-weight:600;color:var(--g5);}
.auth-fg input{border:var(--border);border-radius:var(--r);padding:12px 14px;font-size:14.5px;outline:none;font-family:'Plus Jakarta Sans',sans-serif;transition:border-color .15s;background:#fff;}
.auth-fg input:focus{border-color:var(--s);}
.auth-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.auth-submit{width:100%;padding:14px;background:var(--s);color:#fff;border:none;border-radius:var(--r);font-size:15px;font-weight:700;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:background .15s;margin-top:4px;}
.auth-submit:hover{background:var(--s2);}
.auth-toggle{text-align:center;font-size:13.5px;color:var(--g4);margin-top:20px;}
.auth-toggle a{color:var(--s);font-weight:600;cursor:pointer;}
.auth-divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--g3);font-size:12px;}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--g2);}
.auth-err{background:#FEF2F2;border:1px solid #FECACA;color:#B91C1C;border-radius:var(--r);padding:10px 14px;font-size:13px;margin-bottom:16px;display:none;}
.auth-ok{background:#F0FDF4;border:1px solid #BBF7D0;color:#15803D;border-radius:var(--r);padding:10px 14px;font-size:13px;margin-bottom:16px;display:none;}
/* Dashboard */
.dash-wrap{min-height:100vh;background:var(--off);overflow-y:auto;}
.dash-header{background:#fff;border-bottom:var(--border);padding:0;display:flex;align-items:center;justify-content:space-between;height:64px;}
.dash-header .wrap{display:flex;align-items:center;justify-content:space-between;width:100%;}
.dash-user{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--n);}
.dash-avatar{width:34px;height:34px;border-radius:50%;background:var(--s);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;}
.dash-logout{font-size:13px;color:var(--g4);cursor:pointer;padding:8px 14px;border-radius:var(--r);border:var(--border);background:#fff;transition:all .15s;}
.dash-logout:hover{border-color:var(--err);color:var(--err);}
.dash-body{padding:40px 0 80px;}
.dash-grid{display:grid;grid-template-columns:240px 1fr;gap:28px;align-items:start;}
.dash-nav{background:#fff;border:var(--border);border-radius:var(--r2);padding:8px;}
.dash-nav-item{display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:var(--r);font-size:14px;font-weight:500;cursor:pointer;color:var(--g5);transition:all .15s;}
.dash-nav-item:hover{background:var(--g1);color:var(--n);}
.dash-nav-item.on{background:var(--sp);color:var(--s);font-weight:700;}
.dash-nav-icon{font-size:16px;width:20px;text-align:center;}
.dash-panel{display:none;}
.dash-panel.on{display:block;}
.dash-panel-h{font-family:'Lora',serif;font-size:22px;color:var(--n);margin-bottom:4px;}
.dash-panel-sub{font-size:13.5px;color:var(--g4);margin-bottom:24px;}
.dash-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:28px;}
.dash-stat{background:#fff;border:var(--border);border-radius:var(--r2);padding:18px 20px;}
.dash-stat-n{font-size:28px;font-weight:700;color:var(--n);font-family:'Lora',serif;}
.dash-stat-l{font-size:12.5px;color:var(--g4);margin-top:3px;}
.dash-empty{text-align:center;padding:52px 20px;color:var(--g4);}
.dash-empty-icon{font-size:44px;margin-bottom:14px;}
.req-list{display:flex;flex-direction:column;gap:12px;}
.req-item{background:#fff;border:var(--border);border-radius:var(--r2);padding:18px 20px;}
.req-item-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:8px;}
.req-item-h{font-size:14.5px;font-weight:700;color:var(--n);}
.req-badge{font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;white-space:nowrap;}
.req-badge.pending{background:#FEF3C7;color:#92400E;}
.req-badge.active{background:#F0FDF4;color:#15803D;}
.req-badge.done{background:#EEF2FF;color:#3730A3;}
.req-item-meta{font-size:12.5px;color:var(--g4);}
.dash-bid-type{padding:9px 16px;border-radius:var(--r);border:1.5px solid var(--g2);font-size:13px;font-weight:600;cursor:pointer;color:var(--g5);transition:all .15s;}
.dash-bid-type:hover{border-color:var(--s);color:var(--s);}
.dash-bid-type.on{background:var(--sp);border-color:var(--s);color:var(--s);}
@media(max-width:768px){
  /* Auth page */
  .auth-wrap{grid-template-columns:1fr;background:#fff;}
  .auth-left{display:none;}
  .auth-right{padding:32px 20px;min-height:100vh;align-items:flex-start;padding-top:48px;background:var(--off);}
  .auth-form-box{max-width:100%;background:transparent;border:none;box-shadow:none;padding:0;}
  .auth-mobile-brand{display:none !important;}
  .auth-row{grid-template-columns:1fr;}
  .auth-tab-row{margin-bottom:24px;}
  .auth-submit{font-size:15px;padding:14px;}
  /* Dashboard */
  .dash-grid{grid-template-columns:1fr;}
  .dash-nav{display:flex;flex-wrap:wrap;gap:4px;padding:6px;}
  .dash-nav-item{font-size:12.5px;padding:8px 10px;}
  .dash-stats{grid-template-columns:1fr 1fr 1fr;}
  /* Dash form panels on mobile */
  #dp-bid .auth-row,
  #dp-quotation .auth-row,
  #dp-enquiry .auth-row,
  #dp-newreq .auth-row,
  #dp-profile .auth-row{grid-template-columns:1fr;}
  /* Bid type row wraps nicely */
  #db-type-row{gap:8px;}
  .dash-bid-type{font-size:12px;padding:8px 12px;}
  /* Dashboard header */
  .dash-header .wrap{padding:0 16px;}
  .dash-user span{display:none;}
  .dash-body{padding:24px 0 60px;}
}
@media(max-width:400px){
  .auth-right{padding:24px 14px;}
  .auth-form-box{padding:24px 18px 20px;}
  .auth-tab-row{gap:2px;}
  .auth-tab{font-size:13px;padding:9px 8px;}
  .auth-form-h{font-size:22px;}
  .dash-stats{grid-template-columns:1fr;}
}
