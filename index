  div.appendChild(btn);
  el.appendChild(div);
}


function getTrackSteps(type){
  if(type==='Offline Quotation')
    return ['Submitted','Reviewing','Quotation Sent','Completed'];
  if(type==='GeM Bid')
    return ['Submitted','Assessing','Bid Filed','Completed'];
  if(type==='Enquiry')
    return ['Submitted','Reviewing','Responded','Resolved'];
  return ['Submitted','Processing','Quotation Ready','Completed'];
}

function maskSimple(val){
  // Show only first character, hide the rest
  if(!val) return '';
  var s = String(val).trim();
  return s[0] + '*****';
}

function maskProductName(name, loggedIn){
  if(loggedIn) return name;
  var words = name.trim().split(/\s+/);
  // First letter of first word + ***** + last letter of last word
  var firstChar = words[0][0];
  var lastWord  = words[words.length - 1];
  var lastChar  = lastWord[lastWord.length - 1];
  if(words.length === 1){
    return firstChar + '*****' + lastChar;
  }
  return firstChar + '***** ' + lastChar;
}

function buildTrackCardHtml(r){
  var loggedIn = (typeof currentUser !== 'undefined' && currentUser);
  var badgeCls = r.status==='Completed'?'done': r.status==='Active'?'active':'pending';
  var steps = getTrackSteps(r.type);
  var curIdx = r.status==='Completed'? steps.length-1 : r.status==='Active'? 1 : 0;
  var stepsHtml = steps.map(function(s,i){
    var cls = i<curIdx?'ts-done': i===curIdx?'ts-cur':'';
    var dot = i<curIdx?'&#10003;': i===curIdx?'&#9679;':'';
    return '<div class="track-step '+cls+'"><div class="track-dot">'+dot+'</div>'+
           '<div class="track-step-lbl">'+s+'</div></div>';
  }).join('');
  var icons = {'Product Request':'&#128230;','Amazon\u2192GeM':'&#128722;','GeM Bid':'&#127991;','Offline Quotation':'&#128196;','Enquiry':'&#9993;'};
  var icon = icons[r.type] || '&#128230;';
  var waNum = (typeof DB!=='undefined'&&DB.settings&&DB.settings.wa)?DB.settings.wa:'919588173625';
  var waMsg = encodeURIComponent('Hello Hues MyIndia, follow-up on Tracking ID: '+r.trackId+' | Product: '+r.product+' | Date: '+r.date);

  // Apply masking for non-logged-in users
  var displayProduct = maskProductName(r.product, loggedIn);
  var displayQty     = loggedIn ? r.qty    : (r.qty    ? maskSimple(r.qty)    : '');
  var displayBudget  = loggedIn ? r.budget : (r.budget ? maskSimple(r.budget) : '');

  var loginNote = loggedIn ? '' :
    '<div style="font-size:11.5px;color:var(--g4);margin-bottom:10px;padding:7px 10px;background:var(--off);border-radius:6px;border-left:3px solid var(--s);">'+
    '<a href="#" onclick="goPage(\'login\');return false;" style="color:var(--s);font-weight:700;">Sign in</a> to view full details.</div>';

  var info = loginNote;
  if(r.qty)    info += '<div class="track-info-item"><label>Quantity</label><span>'+displayQty+'</span></div>';
  if(r.budget) info += '<div class="track-info-item"><label>Est. Budget</label><span>'+displayBudget+'</span></div>';
  info += '<div class="track-info-item"><label>Date Submitted</label><span>'+r.date+'</span></div>';
  info += '<div class="track-info-item"><label>Request Type</label><span>'+r.type+'</span></div>';

  return '<div class="track-card">'+
    '<div class="track-card-top">'+
      '<div class="track-card-icon">'+icon+'</div>'+
