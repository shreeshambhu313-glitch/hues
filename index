function moveCat(id,dir){
  const i=DB.categories.findIndex(c=>c.id===id);
  if(i<0) return;
  const ni=i+dir;
  if(ni<0||ni>=DB.categories.length) return;
  [DB.categories[i],DB.categories[ni]]=[DB.categories[ni],DB.categories[i]];
  renderAdminCats();populateCatSel();populateAdminCatFilter();renderCatGrid();renderFooterCats();
}
function initCatDrag(){
  const tb=document.getElementById('cats-body');if(!tb)return;
  let dragSrc=null;
  tb.querySelectorAll('.cat-drag-row').forEach(row=>{
    row.ondragstart=e=>{dragSrc=row;row.style.opacity='.4';e.dataTransfer.effectAllowed='move';};
    row.ondragend=e=>{dragSrc.style.opacity='';tb.querySelectorAll('.cat-drag-row').forEach(r=>r.style.background='');};
    row.ondragover=e=>{e.preventDefault();e.dataTransfer.dropEffect='move';row.style.background='rgba(232,101,26,.07)';return false;};
    row.ondragleave=e=>{row.style.background='';};
    row.ondrop=e=>{
      e.stopPropagation();
      if(dragSrc===row){row.style.background='';return;}
      const ids=[...tb.querySelectorAll('.cat-drag-row')].map(r=>r.dataset.catid);
      const fromId=dragSrc.dataset.catid, toId=row.dataset.catid;
      const fi=DB.categories.findIndex(c=>c.id===fromId);
      const ti=DB.categories.findIndex(c=>c.id===toId);
      if(fi<0||ti<0){row.style.background='';return;}
      const [moved]=DB.categories.splice(fi,1);
      DB.categories.splice(ti,0,moved);
      renderAdminCats();populateCatSel();populateAdminCatFilter();renderCatGrid();renderFooterCats();
      showToast('Order updated!','ok');
    };
  });
}
