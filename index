function addBrand(){
  const name=document.getElementById('nb-name').value.trim();
  if(!name){showToast('Enter a brand name.','err');return;}
  const logo=document.getElementById('nb-logo').value.trim()||document.getElementById('nb-emoji').value.trim()||'';
  const url=document.getElementById('nb-url').value.trim();
  DB.brands.items.push({id:'br'+Date.now(),name,logo,url});
  ['nb-name','nb-logo','nb-url','nb-emoji'].forEach(id=>document.getElementById(id).value='');
  renderBrandsAdmin();
  renderBrandsSec();
  showToast('Brand added!','ok');
}

function deleteBrand(id){
  DB.brands.items=DB.brands.items.filter(b=>b.id!==id);
  renderBrandsAdmin();
  renderBrandsSec();
  showToast('Brand removed.','ok');
}

function renderBrandsAdmin(){
  const vis=document.getElementById('brands-vis');
  const lbl=document.getElementById('brands-vis-label');
  if(vis) vis.checked=DB.brands.visible;
  if(lbl) lbl.textContent=DB.brands.visible?'On':'Off';
  const tbody=document.getElementById('brands-body');
  if(!tbody) return;
  tbody.innerHTML=DB.brands.items.length
    ? DB.brands.items.map(b=>`<tr>
        <td style="font-size:20px;text-align:center">${b.logo&&!b.logo.startsWith('http')?b.logo:b.logo?`<img src="${b.logo}" style="height:28px;object-fit:contain" onerror="this.outerHTML='—'"/>`:'—'}</td>
