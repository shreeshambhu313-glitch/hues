  // Catalogue matches
  const matches=DB.products
    .filter(p=>p.active!==false)
    .map(p=>({p,score:Math.max(fuzzyScore(p.name,q),fuzzyScore(p.brand||'',q),fuzzyScore(p.desc||'',q),fuzzyScore(p.hsn||'',q))}))
    .filter(x=>x.score>5).sort((a,b)=>b.score-a.score).slice(0,4);

  let html='';

  if(matches.length){
