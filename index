function openShare(){
  const p=DB.products.find(x=>x.id===(shareProdId||curProd));if(!p) return;
  const link=`https://huesmyindia.in/product/${p.id}/${p.name.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')}`;
  document.getElementById('share-link-val').value=link;
  document.getElementById('sh-wa').onclick=()=>{
    const wa=encodeURIComponent(`Check out this product on Hues MyIndia: ${p.name}\n${link}`);
    window.open(`https://wa.me/?text=${wa}`,'_blank');
  };
  document.getElementById('share-modal').classList.remove('hidden');
}
function closeShare(){document.getElementById('share-modal').classList.add('hidden');shareProdId=null;}
function doShare(type){
  const p=DB.products.find(x=>x.id===(shareProdId||curProd));if(!p) return;
  const link=document.getElementById('share-link-val').value;
  const text=`Check out this product on Hues MyIndia: ${p.name}\n${link}`;
  if(type==='wa'){const wa=encodeURIComponent(text);window.open(`https://wa.me/?text=${wa}`,'_blank');}
  else if(type==='copy'){navigator.clipboard?.writeText(link).then(()=>showToast('Link copied!','ok')).catch(()=>copyShareLink());}
  else if(type==='sms'){window.location.href=`sms:?body=${encodeURIComponent(text)}`;}
  else if(type==='email'){window.location.href=`mailto:?subject=${encodeURIComponent(p.name)}&body=${encodeURIComponent(text)}`;}
  if(type!=='copy') closeShare();
}
function copyShareLink(){
  const input=document.getElementById('share-link-val');
  input.select(); document.execCommand('copy');
  showToast('Link copied!','ok');
}

