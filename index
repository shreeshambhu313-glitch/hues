  const email=document.getElementById('offq-email')?.value.trim()||'';
  if(email&&!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){markErr('offq-email','Enter a valid email address');return;}
  // Build address strings
  const billAddr=[billStreet,billArea,billCity,billState,billPin].filter(Boolean).join(', ');
