let bidPageType='product', bidQcat='q3';
let prodBidItems=[], customBidItems=[], boqBidItems=[];
let bidDocFiles=[], boqDocFiles=[];

function openBidForm(){
  // Navigate to full bid page
  goPage('bid');
}
