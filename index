  var pending   = allReqs.filter(function(r){ return r.status==='Pending'; }).length;
  var active    = allReqs.filter(function(r){ return r.status==='Active'; }).length;
  var done      = allReqs.filter(function(r){ return r.status==='Completed'; }).length;

  // Overview panel stats
  var el;
  el=document.getElementById('ds-total');  if(el) el.textContent=allReqs.length;
  el=document.getElementById('ds-active'); if(el) el.textContent=allReqs.filter(function(r){return r.status!=='Completed';}).length;
  el=document.getElementById('ds-done');   if(el) el.textContent=done;

  // Requests panel stats
  el=document.getElementById('rst-total');   if(el) el.textContent=allReqs.length;
  el=document.getElementById('rst-pending'); if(el) el.textContent=pending;
  el=document.getElementById('rst-active');  if(el) el.textContent=active;
  el=document.getElementById('rst-done');    if(el) el.textContent=done;

