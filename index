      </div>`;
    }).join('');
  }

  // No catalogue results - show contact strip
  if(!matches.length){
    const waMsg=encodeURIComponent(`Hello Hues MyIndia, I am looking for: ${q}`);
    html+=`<div class="gsr-no-results">
      <div class="gsr-no-title">No products found for "<strong>${q}</strong>"</div>
      <div class="gsr-no-sub">We can still procure it via GeM — contact us directly:</div>
      <div class="gsr-contact-strip">
        <button class="gsr-contact-btn req" onclick="openReqWithText('${q.replace(/'/g,"\\'")}')">📝 Request New Product</button>
        <a href="https://wa.me/${DB.settings.wa}?text=${waMsg}" target="_blank" class="gsr-contact-btn wa">💬 WhatsApp</a>
        <a href="tel:${DB.settings.phone}" class="gsr-contact-btn call">📞 Call</a>
      </div>
    </div>`;
  }

  // Web results section - always show with spinner, then populate
  html+=`<div class="gsr-web-head">
    <span class="gsr-web-badge" id="gsr-engine-badge">🔍 Web Results</span>
    <span class="gsr-web-hint">Tap any result to request via GeM</span>
  </div>
  <div id="gsr-web-body"><div class="gsr-web-loading"><div class="gsr-web-spinner"></div>Searching…</div></div>`;

  res.innerHTML=html;
  res.classList.add('open');

  // Debounce web fetch
  clearTimeout(gsWebTimeout);
  gsWebTimeout=setTimeout(()=>fetchWebResults(q),500);
}

/* ── WEB RESULTS FETCH - Serper (primary) / Google CSE / Bing ── */
async function fetchWebResults(q){
  const body = document.getElementById('gsr-web-body');
  if(!body) return;

  if(location.protocol==='file:'){
    body.innerHTML=`<div class="gsr-web-error">⚠️ Web search works after deployment to Netlify.</div>`;
    return;
  }

  const engine = DB.settings.searchEngine;

  if(engine==='serper' && DB.settings.serperKey){
    await fetchSerper(q, body);
  } else if(engine==='google' && DB.settings.gcseKey && DB.settings.gcseCx){
    await fetchGoogleCSE(q, body);
  } else if(engine==='bing' && DB.settings.bingKey){
    await fetchBing(q, body);
  } else {
    // No key configured for selected engine
    const names = {serper:'Serper.dev', google:'Google CSE', bing:'Bing'};
    body.innerHTML=`<div class="gsr-web-error">⚙️ ${names[engine]||'Web search'} not configured yet.<br><span style="font-size:11px">Add API key in Admin → Settings.</span></div>`;
  }
}

/* ── SERPER.DEV (primary - 2,500 free/month, Google results) ── */
async function fetchSerper(q, body){
  try{
    const res = await fetch('https://google.serper.dev/search', {
      method:'POST',
      headers:{'X-API-KEY': DB.settings.serperKey, 'Content-Type':'application/json'},
      body: JSON.stringify({q: q+' buy India', num:6}),
      signal: AbortSignal.timeout(8000)
    });
    const data = await res.json();
    if(data.error){ body.innerHTML=`<div class="gsr-web-error">Serper: ${data.error}</div>`; return; }
    const items = (data.organic||[]).map(r=>({
      title: r.title, url: r.link||'', snippet: r.snippet||'',
      source: (r.displayLink||r.link||'').replace(/^https?:\/\/(www\.)?/,'').split('/')[0]
    }));
    renderWebResults(items, body, 'Serper');
  } catch(e){
    body.innerHTML=`<div class="gsr-web-error">⚠️ Serper unavailable. Try again shortly.</div>`;
  }
}

