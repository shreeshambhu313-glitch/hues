  var area = document.getElementById(areaId);
  if(area) area.innerHTML = '';
}

function confirmAmzAction(ctx, action){
  var qty    = parseInt(document.getElementById(ctx+'-amz-qty')?document.getElementById(ctx+'-amz-qty').value:1)||1;
  var pin    = (document.getElementById(ctx+'-amz-pin')   ?document.getElementById(ctx+'-amz-pin').value   :'').trim();
  var budget = (document.getElementById(ctx+'-amz-budget')?document.getElementById(ctx+'-amz-budget').value:'').trim();
  var data   = getAmzContext(ctx);

  // Read price from form input (always present in form)
  var priceInp = document.getElementById(ctx+'-amz-price-inp');
  var formAmzPrice = priceInp ? parseFloat(priceInp.value)||0 : data.amzPrice;
  if(formAmzPrice > 0){
    data.amzPrice = formAmzPrice;
    var pctC = (typeof DB!=='undefined'&&DB.services)?DB.services.amzPct||10:10;
    data.gemPrice = data.gemPrice || Math.ceil(formAmzPrice*(1+pctC/100));
  }
  if(!formAmzPrice){
    showToast('Please enter the Amazon price.','err');
    if(priceInp){ priceInp.style.borderColor='var(--err)'; priceInp.focus(); }
    return;
  }
  if(!pin||pin.length!==6||!/^\d{6}$/.test(pin)){
    showToast('Please enter a valid 6-digit pincode.','err'); return;
  }

  var pctFinal = (typeof DB!=='undefined'&&DB.services)?DB.services.amzPct||10:10;
  if(!data.gemPrice && data.amzPrice) data.gemPrice = Math.ceil(data.amzPrice*(1+pctFinal/100));
  var totalGem = data.gemPrice * qty;
  var revealId = ctx+'-amz-reveal';

  if(action==='cart'){
    // Add to cart with qty and pin
    addAmzToCartFull(data.title, data.url, data.gemPrice, qty, pin);
    // Replace form with cart-added state
    var areaId = ctx==='da'?'da-action-form-area':ctx==='gem'?'gem-action-form-area':'calc-action-form-area';
    var area = document.getElementById(areaId);
    if(area){
      area.innerHTML =
        '<div style="display:flex;align-items:center;gap:10px;background:#F0FDF4;border:1.5px solid #86EFAC;border-radius:var(--r);padding:10px 14px;margin-top:6px;">'+
          '<span style="font-size:18px;">&#10003;</span>'+
          '<div style="flex:1;font-size:13.5px;font-weight:600;color:#15803D;">Added to cart &mdash; '+qty+' unit'+(qty>1?'s':'')+', Pin: '+pin+'</div>'+
          '<div style="display:flex;align-items:center;border:1.5px solid var(--s);border-radius:7px;overflow:hidden;">'+
            '<button style="width:30px;height:30px;border:none;background:var(--g1);font-size:16px;font-weight:700;cursor:pointer;font-family:inherit;" onclick="amzCartQtyAdj(\''+ctx+'\', \''+data.url+'\', -1)">&#8722;</button>'+
            '<span id="'+ctx+'-cart-qty-display" style="padding:0 10px;font-size:13px;font-weight:700;color:var(--n);">'+qty+'</span>'+
            '<button style="width:30px;height:30px;border:none;background:var(--g1);font-size:16px;font-weight:700;cursor:pointer;font-family:inherit;" onclick="amzCartQtyAdj(\''+ctx+'\', \''+data.url+'\', 1)">+</button>'+
          '</div>'+
        '</div>';
    }
  } else {
    // Request with tracking
    submitAmzRequest(data.title, data.url, data.amzPrice, totalGem, qty, pin, budget);
    // Show reveal inside form
    var revealEl = document.getElementById(revealId);
