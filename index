/* ── RENDER WEB RESULTS ── */
function renderWebResults(results, body, engine){
  const badge = document.getElementById('gsr-engine-badge');
  const icons = {Serper:'🔍', Google:'🔍', Bing:'🔎'};
  if(badge) badge.textContent = (icons[engine]||'🔍')+' '+engine+' Results';
  if(!results.length){
    body.innerHTML=`<div class="gsr-web-error">No results found. Try a different search.</div>`;
    return;
  }
  body.innerHTML = results.map((r,i)=>{
    const safeT = r.title.replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    const safeU = (r.url||'').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    const favicon = `https://www.google.com/s2/favicons?domain=${r.source}&sz=16`;
    return `<div class="gsr-web-item" onclick="gsWebConfirm('${safeT}','${safeU}')">
      <div class="gsr-web-item-left">
        <div class="gsr-web-source">
          <img src="${favicon}" onerror="this.style.display='none'" style="width:14px;height:14px;border-radius:2px;margin-right:4px;vertical-align:middle"/>
          ${r.source}
        </div>
        <div class="gsr-web-title">${r.title}</div>
        ${r.snippet?`<div class="gsr-web-snippet">${r.snippet.substring(0,110)}…</div>`:''}
      </div>
      <button class="gsr-web-req-btn" onclick="event.stopPropagation();gsWebConfirm('${safeT}','${safeU}')">Request →</button>
    </div>`;
  }).join('');
}

