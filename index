/* ══ AMAZON-STYLE GALLERY ZOOM ══ */
function galZoomMove(e){
  const gm=document.getElementById('gal-main');
  const img=document.getElementById('gal-main-img');
  const zr=document.getElementById('zoom-result');
  const zri=document.getElementById('zoom-result-img');
  if(!img||!zr||!zri) return;

  // On mobile - skip hover zoom (handled by lightbox tap)
  if(window.innerWidth<768){return;}

  const rect=gm.getBoundingClientRect();
  const x=e.clientX-rect.left;
  const y=e.clientY-rect.top;

  // Show zoom panel
  zr.style.display='block';
  zri.src=img.src;

  // Zoom ratio
  const zoomRatio=4.2;
  const zrW=zr.offsetWidth, zrH=zr.offsetHeight;
  const imgW=rect.width, imgH=rect.height;

  // Position the zoomed image inside the result panel
  const pctX=x/imgW, pctY=y/imgH;
  const scaledW=imgW*zoomRatio, scaledH=imgH*zoomRatio;
  const offsetX=-(pctX*scaledW - zrW/2);
  const offsetY=-(pctY*scaledH - zrH/2);

  zri.style.width=scaledW+'px';
  zri.style.height=scaledH+'px';
  zri.style.left=Math.min(0,Math.max(zrW-scaledW,offsetX))+'px';
  zri.style.top=Math.min(0,Math.max(zrH-scaledH,offsetY))+'px';

  // Draw lens
  let lens=gm.querySelector('.zoom-lens');
  if(!lens){lens=document.createElement('div');lens.className='zoom-lens';gm.appendChild(lens);}
  const lW=lens.offsetWidth||160, lH=lens.offsetHeight||160;
  lens.style.left=Math.max(0,Math.min(imgW-lW, x-lW/2))+'px';
  lens.style.top=Math.max(0,Math.min(imgH-lH, y-lH/2))+'px';
  lens.style.display='block';
}

function galZoomLeave(){
  const zr=document.getElementById('zoom-result');
  if(zr) zr.style.display='none';
